            { id: 35, nombre: "PROTEINA ISO 100 (6.4 LB) + SHAKER", marca: "Dymatize", categoria: "proteinas", precio: 78990, precioAnterior: 104000, descCorta: "Aislado e hidrolizado. Cero lactosa.", descLarga: "La ISO 100 es mundialmente conocida por su calidad, sabor y pureza. Proteína hidrolizada. Incluye Shaker de regalo.", imagenes: ["http://usafitness.cl/wp-content/uploads/2026/04/Sobre-6-Unidades-A-29.990-cu-6.png"], sabores: ["Chocolate", "Vainilla", "Galletas", "Frutilla", "Chocolate peanut Butter", "Fudge Brownie", "chocolate coco nut", "Strawberry", "Cookies & Cream", "Banana", "Fruity Pebbles", "Cocoa Pebbles", "Cinnamon Churro"], calificacion: 4.8, numResenas: 521, destacado: true },
            { id: 41, nombre: "CELLTECH 6 LBS", marca: "MuscleTech", categoria: "creatinas", precio: 62990, precioAnterior: 62990, descCorta: "Creatina con carbohidratos para volumen.", descLarga: "Fórmula avanzada de creatina. Ayuda a mejorar la absorción de nutrientes en las células logrando un aumento de fuerza.", imagenes: ["http://usafitness.cl/wp-content/uploads/2022/11/cell-tech-6lb.png "], sabores: ["Sin sabor"], calificacion: 4.7, numResenas: 214, destacado: false },
