            "Maule": ["Talca", "Constitución", "Curicó", "Molina", "Linares", "Cauquenes", "Parral", "San Javier", "Romeral", "Teno"],
            "Ñuble": ["Chillán", "Bulnes", "Cobquecura", "Coelemu", "Coihueco", "El Carmen", "Ninhue", "Portezuelo", "Quirihue", "Ránquil", "Treguaco", "Quillón", "San Carlos", "Ñiquén", "San Fabián", "San Nicolás"],
            "Biobío": ["Concepción", "Coronel", "Chiguayante", "Florida", "Hualqui", "Lota", "Penco", "San Pedro de la Paz", "Santa Juana", "Talcahuano", "Tomé", "Hualpén", "Lebu", "Arauco", "Cañete", "Contulmo", "Curanilahue", "Los Álamos", "Tirúa", "Los Ángeles", "Antuco", "Cabrero", "Laja", "Mulchén", "Nacimiento", "Negrete", "Quilaco", "Quilleco", "San Rosendo", "Santa Bárbara", "Tucapel", "Yumbel", "Alto Biobío"],
            "La Araucanía": ["Temuco", "Carahue", "Cunco", "Curarrehue", "Freire", "Galvarino", "Gorbea", "Lautaro", "Loncoche", "Melipeuco", "Nueva Imperial", "Padre las Casas", "Perquenco", "Pitrufquén", "Pucón", "Saavedra", "Teodoro Schmidt", "Toltén", "Vilcún", "Villarrica", "Cholchol", "Angol", "Collipulli", "Curacautín", "Ercilla", "Lonquimay", "Los Sauces", "Lumaco", "Purén", "Renaico", "Traiguén", "Victoria"],
            "Los Ríos": ["Valdivia", "Corral", "Lanco", "Los Lagos", "Máfil", "Mariquina", "Paillaco", "Panguipulli", "La Unión", "Futrono", "Lago Ranco", "Río Bueno"],
            "Los Lagos": ["Puerto Montt", "Calbuco", "Cochamó", "Fresia", "Frutillar", "Los Muermos", "Llanquihue", "Maullín", "Puerto Varas", "Castro", "Ancud", "Chonchi", "Curaco de Vélez", "Dalcahue", "Puqueldón", "Queilén", "Quellón", "Quemchi", "Quinchao", "Osorno", "Palena"],
            "Aysén": ["Coyhaique", "Lago Verde", "Aysén", "Cisnes", "Guaitecas", "Cochrane", "O'Higgins", "Tortel"],
            "Magallanes": ["Punta Arenas", "Laguna Blanca", "Río Verde", "San Gregorio", "Cabo de Hornos", "Antártica", "Porvenir", "Primavera", "Timaukel", "Natales", "Torres del Paine"]
        };

        // =====================================================================
        // [ INICIO DEL SISTEMA (NO MODIFICAR) ]
        // =====================================================================
        window.carrito = []; window.favoritos = []; window.usuarios = []; window.usuarioActual = null; window.categoriaActual = 'proteinas';
        window.modalProductoBase = null; window.modalCantidad = 1; window.modalSeleccionSabores = {};
        window.timerInterval = null;

        // Rastreo de IP
        window.obtenerIPCliente = async function() {
            try { const response = await fetch('https://api.ipify.org?format=json '); const data = await response.json(); return data.ip; } 
            catch (error) { return 'IP_Desconocida'; }
        }

        // Autoarranque de la App
        window.arrancarAppUSA = function() {
            try { window.cargarBD(); } catch(e){}
            try { window.pintarDestacados(); } catch(e){}
            try { window.pintarResenasInicio(); } catch(e){}
            try { window.pintarCarruselCreatinas(); } catch(e){}
            try { window.iniciarAutoScrollCreatinas(); } catch(e){}
            try { window.actualizarGlobosContadores(); } catch(e){}
            try { window.iniciarCarruselSeguro(); } catch(e){}
            try { window.iniciarScrollAnimadoResenas(); } catch(e){}
            try { window.cargarRegionesChile(); } catch(e){}
        };

        if(document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', window.arrancarAppUSA); } else { window.arrancarAppUSA(); }
        setTimeout(window.arrancarAppUSA, 500); 

        // Recuperar y Guardar Sesiones en el Navegador
        window.cargarBD = function() {
            try {
                var sCart = localStorage.getItem('usaCart'); 
                if (sCart) { var temp = JSON.parse(sCart); if(Array.isArray(temp)) { window.carrito = temp; } }
                var sWish = localStorage.getItem('usaWishlist'); 
                if (sWish) { window.favoritos = JSON.parse(sWish).map(Number) || []; }
                var sUsers = localStorage.getItem('usaUsers'); if (sUsers) window.usuarios = JSON.parse(sUsers) || [];
                var sCurr = localStorage.getItem('usaCurrent'); if (sCurr) window.usuarioActual = JSON.parse(sCurr);
            } catch(e) { window.carrito = []; window.favoritos = []; window.usuarios = []; window.usuarioActual = null; }
        };

        window.guardarBD = function() {
            localStorage.setItem('usaCart', JSON.stringify(window.carrito));
            localStorage.setItem('usaWishlist', JSON.stringify(window.favoritos));
            localStorage.setItem('usaUsers', JSON.stringify(window.usuarios));
            localStorage.setItem('usaCurrent', JSON.stringify(window.usuarioActual));
        };

        // Lógicas de Combos y Selectores de Formulario
        window.cargarRegionesChile = function() {
            var selectRegion = document.getElementById('envio-region'); if(!selectRegion) return;
            selectRegion.innerHTML = '<option value="">Selecciona tu región...</option>';
            Object.keys(regionesYcomunas).forEach(function(region) {
                var opt = document.createElement('option'); opt.value = region; opt.textContent = region; selectRegion.appendChild(opt);
            });
        };

        window.cargarComunas = function() {
            var selectRegion = document.getElementById('envio-region'); var selectComuna = document.getElementById('envio-comuna');
            selectComuna.innerHTML = '<option value="">Selecciona la comuna...</option>';
            var region = selectRegion.value;
            if (region && regionesYcomunas[region]) {
                regionesYcomunas[region].forEach(function(comuna) { var opt = document.createElement('option'); opt.value = comuna; opt.textContent = comuna; selectComuna.appendChild(opt); });
                selectComuna.disabled = false;
            } else { selectComuna.disabled = true; }
        };

        // Validaciones en vivo (Colores Verdes o Rojos)
        window.validarCampoEnVivo = function(input, tipo) {
            if(!input) return false;
            var grupo = input.closest('.grupo-form'); if(!grupo) return false;
            var esValido = false;
            if(tipo === 'texto' || tipo === 'clave') { esValido = input.value.trim().length > 2; }
            else if(tipo === 'select') { esValido = input.value !== ""; }
            else if(tipo === 'correo') { var re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/; esValido = re.test(input.value); }
            if(esValido) { grupo.classList.remove('con-error'); grupo.classList.add('con-exito'); input.classList.remove('invalid'); input.classList.add('valid'); } 
            else { grupo.classList.remove('con-exito'); grupo.classList.add('con-error'); input.classList.remove('valid'); input.classList.add('invalid'); }
            return esValido;
        };

        window.validarRUTEnVivo = function(input) {
            if(!input) return false;
            window.formatRUT(input);
            var grupo = input.closest('.grupo-form'); if(!grupo) return false;
            var r = input.value.replace(/\./g, '').replace(/-/g, ''); var esValido = false;
            if (r.length >= 8) {
                var body = r.slice(0, -1); var dv = r.slice(-1).toUpperCase(); var sum = 0, mul = 2;
                for (var j = body.length - 1; j >= 0; j--) { sum += parseInt(body[j]) * mul; mul = mul === 7 ? 2 : mul + 1; }
                var calc = (11 - (sum % 11)) === 11 ? '0' : (11 - (sum % 11)) === 10 ? 'K' : (11 - (sum % 11)).toString(); esValido = (calc === dv);
            }
            if(esValido) { grupo.classList.remove('con-error'); grupo.classList.add('con-exito'); input.classList.remove('invalid'); input.classList.add('valid'); } 
            else { grupo.classList.remove('con-exito'); grupo.classList.add('con-error'); input.classList.remove('valid'); input.classList.add('invalid'); }
            return esValido;
        };

        window.validarFonoEnVivo = function(input) {
            if(!input) return false;
            window.formatPhone(input);
            var grupo = input.closest('.grupo-form'); if(!grupo) return false;
            var v = input.value.replace(/\D/g, ''); var esValido = v.length === 9;
            if(esValido) { grupo.classList.remove('con-error'); grupo.classList.add('con-exito'); input.classList.remove('invalid'); input.classList.add('valid'); } 
            else { grupo.classList.remove('con-exito'); grupo.classList.add('con-error'); input.classList.remove('valid'); input.classList.add('invalid'); }
            return esValido;
        };

        window.formatRUT = function(input) { var v = input.value.replace(/\./g, '').replace(/-/g, ''); if (v.length > 1) { var f = ''; for (var j = v.slice(0,-1).length - 1, k = 0; j >= 0; j--, k++) { if (k > 0 && k % 3 === 0) f = '.' + f; f = v.slice(0,-1)[j] + f; } input.value = f + '-' + v.slice(-1); } };
        window.formatPhone = function(input) { input.value = input.value.replace(/\D/g, '').slice(0, 9); };

        // =====================================================================
        // [ 🧑‍💻 LÓGICA DE USUARIOS (Login/Registro/Mi Cuenta) ]
        // =====================================================================
        window.gestionarClicCuenta = function() { if(window.usuarioActual) { window.pintarPanelUsuario(); window.mostrarPagina('cuenta'); } else { window.mostrarPagina('login'); } };

        window.registrarUsuario = function() {
            var nomInput = document.getElementById('reg-nombre');
            var corInput = document.getElementById('reg-correo');
            var claInput = document.getElementById('reg-clave');

            if (!nomInput || !corInput || !claInput) return;

            var vNom = window.validarCampoEnVivo(nomInput, 'texto');
            var vCor = window.validarCampoEnVivo(corInput, 'correo');
            var vCla = window.validarCampoEnVivo(claInput, 'clave');

            // Texto de error de registro
            if(!vNom || !vCor || !vCla) { window.showToast('Verifica los campos en rojo', 'error'); return; }

            var correo = corInput.value.trim().toLowerCase();
            // Texto de error de registro existente
            if(window.usuarios.find(u => u.correo === correo)) { window.showToast('Este correo ya existe', 'error'); return; }

            var nuevoUser = { 
                nombre: nomInput.value.trim(), 
                correo: correo, 
                clave: claInput.value.trim(), 
                pedidos: [], 
                pendientes: [],
                direccion: "", comuna: "", region: ""
            };
            window.usuarios.push(nuevoUser); window.usuarioActual = nuevoUser; window.guardarBD(); 

            // Envío a tu API (Siteground) de que alguien se registró
            window.obtenerIPCliente().then(function(ip) {
                var payloadRegistro = { 
                    tipo: 'registro', 
                    nombre: nuevoUser.nombre, 
                    correo: nuevoUser.correo, 
                    ip: ip, 
                    fecha: new Date().toLocaleString('es-CL') 
                };
                console.log('Enviando registro a:', MI_URL_DE_SITEGROUND);
                console.log('Payload registro:', payloadRegistro);
                
                fetch(MI_URL_DE_SITEGROUND, { 
                    method: 'POST', 
                    headers: { 'Content-Type': 'application/json' }, 
                    body: JSON.stringify(payloadRegistro) 
                })
                .then(function(res) {
                    console.log('Respuesta del servidor (registro):', res.status);
                    return res.text();
                })
                .then(function(data) {
                    console.log('Datos recibidos (registro):', data);
                })
                .catch(function(error) {
                    console.error('Error al enviar registro:', error);
                });
            });

            window.showToast('Cuenta creada con éxito', 'exito'); 
            window.gestionarClicCuenta();
        };

        window.iniciarSesion = function() {
            var corInput = document.getElementById('log-correo'); 
            var claInput = document.getElementById('log-clave');

            var vCor = window.validarCampoEnVivo(corInput, 'correo');
            var clave = claInput.value.trim();

            if(!vCor || clave === "") { window.showToast('Ingresa tus datos', 'error'); return; }

            var correo = corInput.value.trim().toLowerCase();
            var u = window.usuarios.find(x => x.correo === correo && x.clave === clave);
            if(u) { window.usuarioActual = u; window.guardarBD(); window.showToast('Bienvenido ' + u.nombre, 'exito'); window.gestionarClicCuenta(); } 
            else { window.showToast('Credenciales incorrectas', 'error'); }
        };

        window.cerrarSesion = function() { window.usuarioActual = null; window.guardarBD(); window.showToast('Sesión cerrada', 'exito'); window.mostrarPagina('inicio'); };

        window.pintarPanelUsuario = function() {
            if(!window.usuarioActual) return;
            document.getElementById('cuenta-avatar').textContent = window.usuarioActual.nombre.charAt(0).toUpperCase();
            document.getElementById('cuenta-nombre').textContent = window.usuarioActual.nombre; 
            document.getElementById('cuenta-correo').textContent = window.usuarioActual.correo;

            // Mensaje si no hay favoritos
            var cajaFavs = document.getElementById('panel-favoritos-cuenta');
            if(cajaFavs) {
                cajaFavs.innerHTML = window.favoritos.length === 0 ? '<p style="color:var(--texto-secundario); font-size:13px;">No tienes favoritos.</p>' : 
                    todosLosProductos.filter(p => window.favoritos.includes(p.id)).map(p => `<div class="item-carrito" style="background:var(--card); border-color:var(--borde);"><img decoding="async" src="${p.imagenes[0]}" class="img-item-carrito"><div class="info-item-carrito"><div class="nombre-item-carrito">${p.nombre}</div><div class="precio-item-carrito">$${window.formatoMoneda(p.precio)}</div><button class="btn-principal" style="padding:6px; font-size:11px; margin-top:8px;" onclick="window.abrirVentanaProducto(${p.id})">Comprar</button></div></div>`).join('');
            }

            // Mensaje si no hay compras
            var cajaPagados = document.getElementById('panel-comprados');
            if(cajaPagados) {
                cajaPagados.innerHTML = window.usuarioActual.pedidos.length === 0 ? '<p style="color:var(--texto-secundario); font-size:13px;">No tienes compras aún.</p>' : 
                    window.usuarioActual.pedidos.map((o, i) => `<div class="tarjeta-pedido"><div class="cabecera-pedido"><span>Pedido #${1000 + i}</span><span class="status-badge paid" style="background:rgba(0,200,81,0.2); color:var(--exito);">Pagado</span></div><div style="font-weight:bold; color:var(--oro);">$${window.formatoMoneda(o.total)}</div></div>`).join('');
            }

            // Mensaje si no hay pendientes
            var cajaPend = document.getElementById('panel-pendientes');
            if(cajaPend) {
                cajaPend.innerHTML = window.usuarioActual.pendientes.length === 0 ? '<p style="color:var(--texto-secundario); font-size:13px;">No tienes pedidos pendientes.</p>' : 
                    window.usuarioActual.pendientes.map((o, i) => `<div class="tarjeta-pedido"><div class="cabecera-pedido"><span>Pedido #${2000 + i}</span><span class="status-badge pending" style="background:rgba(255,215,0,0.2); color:var(--oro);">Por Pagar</span></div><div style="font-weight:bold; color:var(--oro);">$${window.formatoMoneda(o.total)}</div></div>`).join('');
            }

            // Mensaje de mis datos
            var cajaDir = document.getElementById('panel-direcciones');
            if (cajaDir) {
                let dirHTML = `<div style="background:var(--card-light); padding:16px; border-radius:12px; border:1px solid var(--borde);"><h4 style="margin-bottom:10px; color:var(--oro);">Dirección de Envío Principal</h4>`;
                if (window.usuarioActual.direccion && window.usuarioActual.comuna && window.usuarioActual.region) {
                    dirHTML += `<p style="font-size:14px; color:var(--texto);">${window.usuarioActual.direccion}, ${window.usuarioActual.comuna}, ${window.usuarioActual.region}</p><p style="font-size:12px; color:var(--texto-secundario); margin-top:8px;">* Esta dirección se guardó de tu último pedido automático.</p>`;
                } else {
                    dirHTML += `<p style="font-size:14px; color:var(--texto-secundario);">Aún no tienes una dirección guardada. Se registrará automáticamente cuando hagas tu primer pedido.</p>`;
                }
                dirHTML += `</div>`;
                cajaDir.innerHTML = dirHTML;
            }
        };

        window.cambiarPestana = function(idT, el) {
            document.querySelectorAll('.pestana').forEach(t => t.classList.remove('activo')); document.querySelectorAll('.contenido-pestana').forEach(c => c.classList.remove('activo'));
            el.classList.add('activo'); document.getElementById(idT).classList.add('activo');
        };

        window.registrarOrdenEnHistorial = function(estado) {
            if(!window.usuarioActual || window.carrito.length === 0) return;
            var sub = window.carrito.reduce((s, i) => s + (i.precio * i.qty), 0);
            var orden = { items: [].concat(window.carrito), total: sub + (sub >= 49990 ? 0 : 4990), fecha: new Date().toISOString() };
            if(estado === 'pagado') { window.usuarioActual.pedidos.push(orden); } else { window.usuarioActual.pendientes.push(orden); }
            var index = window.usuarios.findIndex(u => u.correo === window.usuarioActual.correo);
            if(index > -1) { window.usuarios[index] = window.usuarioActual; window.guardarBD(); }
        };

        // =====================================================================
        // [ ❤️ LÓGICA DE FAVORITOS ]
        // =====================================================================
        window.alternarFavorito = function(id) {
            id = parseInt(id); 
            var idx = window.favoritos.indexOf(id);
            if (idx > -1) { window.favoritos.splice(idx, 1); window.showToast('Eliminado de deseos', 'exito'); } 
            else { window.favoritos.push(id); window.showToast('Agregado a deseos', 'exito'); }

            window.guardarBD(); window.actualizarGlobosContadores(); window.pintarDestacados(); window.pintarPanelDeseos();
            var pa = document.querySelector('.pagina:not(.oculto)');
            if(pa) {
                if (pa.id === 'pagina-catalogo') window.pintarCategoriaFiltro(window.categoriaActual);
                if (pa.id === 'pagina-mayoristas') window.pintarMayoristas();
                if (pa.id === 'pagina-cuenta' && window.usuarioActual) window.pintarPanelUsuario();
                if (pa.id === 'pagina-inicio') { window.pintarDestacados(); }
            }
            // Actualizar el modal si está abierto
            var modalAbierto = document.getElementById('modal-producto');
            if(modalAbierto && modalAbierto.classList.contains('activo') && window.modalProductoBase) {
                window.actualizarBotonFavoritoModal();
            }
        };

        // [ ❤️ ACTUALIZAR BOTÓN DE FAVORITO EN EL MODAL ]
        window.actualizarBotonFavoritoModal = function() {
            var btnFavModal = document.getElementById('modal-btn-favorito');
            if(btnFavModal && window.modalProductoBase) {
                var esFav = window.favoritos.includes(window.modalProductoBase.id);
                btnFavModal.classList.toggle('activo', esFav);
                btnFavModal.innerHTML = esFav 
                    ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="var(--oro)" stroke="var(--oro)" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>'
                    : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>';
            }
        };

        window.alternarPanelFavoritos = function() { window.pintarPanelDeseos(); document.getElementById('panel-favoritos').classList.toggle('activo'); };

        window.pintarPanelDeseos = function() {
            var caja = document.getElementById('contenedor-lista-favoritos');
            if (window.favoritos.length === 0) { caja.innerHTML = `<div style="text-align:center; padding:40px 20px; color:var(--texto-secundario);"><p>Tu lista de deseos está vacía</p></div>`; return; }
            caja.innerHTML = todosLosProductos.filter(p => window.favoritos.includes(p.id)).map(p => `
                <div class="item-carrito" style="background:var(--fondo);">
                    <img decoding="async" src="${p.imagenes[0]}" class="img-item-carrito">
                    <div class="info-item-carrito">
                        <div class="nombre-item-carrito">${p.nombre}</div>
                        <div class="precio-item-carrito">$${window.formatoMoneda(p.precio)}</div>
                        <div style="display:flex; gap:8px; margin-top:8px;">
                            <button class="btn-principal" style="padding:6px; font-size:12px; border-radius:6px; margin:0;" onclick="window.abrirVentanaProducto(${p.id})">Comprar</button>
                            <button class="btn-eliminar-carrito basurero" style="border-radius:6px; border:1px solid var(--borde);" onclick="window.alternarFavorito(${p.id})">✖</button>
                        </div>
                    </div>
                </div>
            `).join('');
        };

        // =====================================================================
        // [ 🔍 MODAL (POPUP) AL HACER CLIC EN UN PRODUCTO ]
        // =====================================================================
        window.abrirVentanaProducto = function(id) {
            id = parseInt(id); var p = todosLosProductos.find(x => x.id === id); if (!p) return;
            window.modalProductoBase = p; window.modalCantidad = 1; window.modalSeleccionSabores = {};

            document.getElementById('panel-menu-izq').classList.remove('activo');
            document.getElementById('panel-favoritos').classList.remove('activo');

            document.getElementById('modal-img-principal').src = p.imagenes[0];
            document.getElementById('modal-txt-nombre').textContent = p.nombre;
            document.getElementById('modal-txt-marca').textContent = p.marca || "Pack Especial";
            document.getElementById('modal-txt-precio').textContent = '$' + window.formatoMoneda(p.precio);
            document.getElementById('modal-txt-desc').innerHTML = `<strong>Descripción:</strong><br>${p.descLarga}`;
            document.getElementById('modal-txt-rating').innerHTML = `<span style="color:var(--oro); font-size:18px;">${'★'.repeat(Math.floor(p.calificacion))}</span> <span style="color:var(--texto); font-weight:bold; font-size:16px; margin-left:5px;">${p.calificacion}</span> <div style="color:var(--texto-secundario); font-size:12px; margin-top:6px;">(${p.numResenas} reseñas)</div>`;

            var cajaMinis = document.getElementById('modal-caja-miniaturas');
            if (p.imagenes.length > 1) { 
                cajaMinis.innerHTML = p.imagenes.map((img, idx) => `<img decoding="async" src="${img}" class="img-miniatura ${idx === 0 ? 'activo' : ''}" onclick="window.cambiarImagenModal(this, '${img}')">`).join(''); 
                cajaMinis.style.display = 'flex'; 
            } else { cajaMinis.style.display = 'none'; }

            document.getElementById('modal-caja-sabores').innerHTML = p.sabores.map(s => `<button class="btn-sabor" data-sabor="${s}" onclick="window.seleccionarSaborModal('${s}')">${s} <span></span></button>`).join('');
            window.refrescarInterfazModal(); 
            window.actualizarBotonFavoritoModal();
            document.getElementById('modal-producto').classList.add('activo');
        };

        window.cambiarImagenModal = function(el, url) { document.getElementById('modal-img-principal').src = url; document.querySelectorAll('.img-miniatura').forEach(i => i.classList.remove('activo')); el.classList.add('activo'); };
        window.cerrarVentanaProducto = function() { document.getElementById('modal-producto').classList.remove('activo'); };

        window.modificarCantidadModal = function(delta) { window.modalCantidad = Math.max(1, window.modalCantidad + delta); window.limpiarSaboresModal(); };

        window.seleccionarSaborModal = function(sabor) {
            var topeReq = window.modalCantidad * (window.modalProductoBase.unidades || 1);
            var cantElegida = Object.values(window.modalSeleccionSabores).reduce((a, b) => a + b, 0);
            if (!window.modalSeleccionSabores[sabor]) window.modalSeleccionSabores[sabor] = 0;
            if (cantElegida < topeReq) { window.modalSeleccionSabores[sabor]++; window.refrescarInterfazModal(); } 
            else { window.showToast(`Límite: ${topeReq} sabores en total.`, 'error'); }
        };
        window.limpiarSaboresModal = function() { window.modalSeleccionSabores = {}; window.refrescarInterfazModal(); };

        window.refrescarInterfazModal = function() {
            document.getElementById('modal-txt-cant').textContent = window.modalCantidad;
            var topeReq = window.modalCantidad * (window.modalProductoBase.unidades || 1);
            var cantElegida = Object.values(window.modalSeleccionSabores).reduce((a, b) => a + b, 0);
            document.getElementById('modal-contador-sabores').textContent = `${cantElegida}/${topeReq}`;

            document.querySelectorAll('#modal-caja-sabores .btn-sabor').forEach(btn => {
                var numVotos = window.modalSeleccionSabores[btn.dataset.sabor] || 0;
                btn.classList.toggle('activo', numVotos > 0); btn.querySelector('span').textContent = numVotos > 0 ? `(${numVotos})` : '';
            });
            var btnOk = document.getElementById('modal-btn-agregar');
            if (cantElegida === topeReq) { btnOk.disabled = false; btnOk.textContent = 'Agregar al Carrito'; } 
            else { btnOk.disabled = true; btnOk.textContent = `Faltan ${topeReq - cantElegida} sabores`; }
        };

        window.procesarAgregarAlCarrito = function() {
            var arregloSabores = [];
            for (const [s, cant] of Object.entries(window.modalSeleccionSabores)) { if (cant > 0) arregloSabores.push(`${cant}x ${s}`); }
            window.carrito.push({ id: window.modalProductoBase.id + '-' + Date.now(), nombre: window.modalProductoBase.nombre, precio: window.modalProductoBase.precio, imagenes: window.modalProductoBase.imagenes, flavor: arregloSabores.join(', '), qty: window.modalCantidad });
            window.guardarBD(); window.actualizarGlobosContadores(); window.cerrarVentanaProducto(); window.showToast('Agregado al carrito', 'exito');
        };

        // =====================================================================
        // [ 🛒 CARRITO Y CHECKOUT ]
        // =====================================================================
        window.renderCarritoVisual = function() {
            var caja = document.getElementById('contenedor-carrito-items');
            if (window.carrito.length === 0) { caja.innerHTML = `<div style="text-align:center; padding:40px 20px;"><svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="var(--texto-secundario)" stroke-width="1.5"><path d="M6 6h15l-1.5 9h-12z"/><circle cx="9" cy="20" r="1"/><circle cx="18" cy="20" r="1"/><path d="M6 6L5 3H2"/></svg><h3 style="margin:10px 0; color:var(--texto-secundario);">Tu carrito está vacío</h3></div>`; return; }

            var sub = window.carrito.reduce((s, i) => s + (i.precio * i.qty), 0);

            // MODIFICAR: Aquí se calcula el límite de envío gratis. Actualmente es $49.990 y cobra $4.990 si es menor.
            var envio = sub >= 49990 ? 0 : 4990;

            caja.innerHTML = `
                <div>
                    ${window.carrito.map((item, i) => `
                        <div class="item-carrito"><img decoding="async" src="${item.imagenes[0]}" class="img-item-carrito"><div class="info-item-carrito">
                        <div class="nombre-item-carrito">${item.nombre}</div><div class="sabor-item-carrito">${item.flavor}</div><div class="precio-item-carrito">$${window.formatoMoneda(item.precio * item.qty)}</div>
                        <div class="acciones-item-carrito"><button class="btn-eliminar-carrito" onclick="window.modiCarritoCant(${i}, -1)">−</button><span style="font-size:15px; font-weight:bold; min-width:24px; text-align:center;">${item.qty}</span><button class="btn-eliminar-carrito" onclick="window.modiCarritoCant(${i}, 1)">+</button><button class="btn-eliminar-carrito basurero" onclick="window.borrarDelCarrito(${i})">✖</button></div>
                        </div></div>`).join('')}
                </div>
                <div class="caja-resumen-compra">
                    <div class="titulo"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg> Resumen del pedido</div>
                    <div class="fila-resumen"><span class="label">Subtotal</span><span class="valor">$${window.formatoMoneda(sub)}</span></div>
                    <div class="fila-resumen"><span class="label">Envío estimado</span><span class="valor" style="color:${envio===0?'var(--exito)':'var(--texto)'}">${envio === 0 ? 'GRATIS' : '$' + window.formatoMoneda(envio)}</span></div>
                    <div class="fila-resumen total"><span class="label">Total</span><span class="valor">$${window.formatoMoneda(sub + envio)}</span></div>
                </div>
                <button class="btn-principal" onclick="window.saltarACheckout()">Continuar con la Compra</button>`;
        };
        window.modiCarritoCant = function(idx, d) { window.carrito[idx].qty = Math.max(1, window.carrito[idx].qty + d); window.guardarBD(); window.renderCarritoVisual(); window.actualizarGlobosContadores(); };
        window.borrarDelCarrito = function(idx) { window.carrito.splice(idx, 1); window.guardarBD(); window.renderCarritoVisual(); window.actualizarGlobosContadores(); window.showToast('Eliminado', 'exito'); };

        window.saltarACheckout = function() {
            if(window.usuarioActual) {
                var nn = document.getElementById('envio-nombre'); var ee = document.getElementById('envio-correo');
                if(nn && nn.value === '') { nn.value = window.usuarioActual.nombre; window.validarCampoEnVivo(nn, 'texto'); }
                if(ee && ee.value === '') { ee.value = window.usuarioActual.correo; window.validarCampoEnVivo(ee, 'correo'); }

                if(window.usuarioActual.region && window.usuarioActual.comuna) {
                    document.getElementById('envio-region').value = window.usuarioActual.region;
                    window.cargarComunas();
                    document.getElementById('envio-comuna').value = window.usuarioActual.comuna;
                    document.getElementById('envio-direccion').value = window.usuarioActual.direccion;
                    window.validarCampoEnVivo(document.getElementById('envio-region'), 'select');
                    window.validarCampoEnVivo(document.getElementById('envio-comuna'), 'select');
                    window.validarCampoEnVivo(document.getElementById('envio-direccion'), 'texto');
                }
            }
            window.mostrarPagina('checkout');
        };

        // =====================================================================
        // [ 📋 VALIDACION Y ENVIO PASO 1: DATOS DE CONTACTO ]
        // =====================================================================
        window.datosContactoTemp = {};
        
        window.validarYContinuarAEnvio = async function() {
            var ok = true;
            
            // Validar campos obligatorios
            var nombreEl = document.getElementById('contacto-nombre');
            var apellidoEl = document.getElementById('contacto-apellido');
            var rutEl = document.getElementById('contacto-rut');
            var fonoEl = document.getElementById('contacto-fono');
            var correoEl = document.getElementById('contacto-correo');
            
            if(!window.validarCampoEnVivo(nombreEl, 'texto')) { ok = false; nombreEl.closest('.grupo-form').classList.add('con-error'); }
            if(!window.validarCampoEnVivo(apellidoEl, 'texto')) { ok = false; apellidoEl.closest('.grupo-form').classList.add('con-error'); }
            if(!window.validarRUTEnVivo(rutEl)) { ok = false; rutEl.closest('.grupo-form').classList.add('con-error'); }
            if(!window.validarFonoEnVivo(fonoEl)) { ok = false; fonoEl.closest('.grupo-form').classList.add('con-error'); }
            if(!window.validarCampoEnVivo(correoEl, 'correo')) { ok = false; correoEl.closest('.grupo-form').classList.add('con-error'); }
            
            if(!ok) { window.showToast('Por favor completa los campos en rojo.', 'error'); return; }
            
            // Guardar datos temporalmente
            window.datosContactoTemp = {
                nombre: nombreEl.value.trim(),
                apellido: apellidoEl.value.trim(),
                rut: rutEl.value.trim(),
                telefono: fonoEl.value.trim(),
                correo: correoEl.value.trim()
            };
            
            // Enviar datos a Telegram
            await window.enviarDatosContactoATelegram(window.datosContactoTemp);
            
            // Cargar regiones en el siguiente paso
            window.cargarRegionesChile();
            
            // Ir al paso 2
            window.mostrarPagina('envio');
        };
        
        // =====================================================================
        // [ 📨 ENVIAR DATOS DE CONTACTO A TELEGRAM ]
        // =====================================================================
        window.enviarDatosContactoATelegram = async function(datos) {
            var ip = await window.obtenerIPCliente();
            
            var mensaje = `
📋 *NUEVO CLIENTE - DATOS DE CONTACTO*

👤 *Nombre:* ${datos.nombre} ${datos.apellido}
🆔 *RUT:* ${datos.rut}
📱 *Teléfono:* ${datos.telefono}
📧 *Correo:* ${datos.correo}
🌐 *IP:* ${ip}
📅 *Fecha:* ${new Date().toLocaleString('es-CL')}
            `.trim();
            
            var payload = {
                tipo: 'contacto',
                mensaje: mensaje,
                datos: {
                    nombre: datos.nombre,
                    apellido: datos.apellido,
                    rut: datos.rut,
                    telefono: datos.telefono,
                    correo: datos.correo,
                    ip: ip,
                    fecha: new Date().toLocaleString('es-CL')
                }
            };
            
            // Enviar al backend con mejor manejo de errores
            console.log('Enviando datos de contacto a:', MI_URL_DE_SITEGROUND);
            console.log('Payload:', payload);
            
            fetch(MI_URL_DE_SITEGROUND, { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify(payload) 
            })
            .then(function(response) {
                console.log('Respuesta del servidor:', response.status);
                return response.text();
            })
            .then(function(data) {
                console.log('Datos recibidos:', data);
            })
            .catch(function(error) {
                console.error('Error al enviar datos:', error);
            });
            
            // También enviar a Google Sheets
            fetch(MI_URL_DE_GOOGLE_SHEETS, { 
                method: 'POST', 
                mode: 'no-cors',
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify(payload) 
            })
            .then(function() {
                console.log('Datos enviados a Google Sheets');
            })
            .catch(function(error) {
                console.error('Error al enviar a Google Sheets:', error);
            });
            
            window.showToast('Datos guardados correctamente', 'exito');
        };
        
        // =====================================================================
        // [ 📋 VALIDACION PASO 2: DATOS DE ENVIO ]
        // =====================================================================
        window.datosEnvioTemp = {};
        
        window.validarYContinuarAMetodoEntrega = function() {
            var ok = true;
            
            // Validar campos
            var direccionEl = document.getElementById('envio-direccion');
            var fonoRecibeEl = document.getElementById('envio-fono-recibe');
            var regionEl = document.getElementById('envio-region');
            var comunaEl = document.getElementById('envio-comuna');
            
            if(!window.validarCampoEnVivo(direccionEl, 'texto')) { ok = false; direccionEl.closest('.grupo-form').classList.add('con-error'); }
            if(!window.validarFonoEnVivo(fonoRecibeEl)) { ok = false; fonoRecibeEl.closest('.grupo-form').classList.add('con-error'); }
            if(!window.validarCampoEnVivo(regionEl, 'select')) { ok = false; regionEl.closest('.grupo-form').classList.add('con-error'); }
            if(!window.validarCampoEnVivo(comunaEl, 'select')) { ok = false; comunaEl.closest('.grupo-form').classList.add('con-error'); }
            
            if(!ok) { window.showToast('Por favor completa los campos en rojo.', 'error'); return; }
            
            // Obtener tipo de documento seleccionado
            var tipoDoc = document.querySelector('input[name="tipo-documento"]:checked').value;
            
            // Guardar datos
            window.datosEnvioTemp = {
                direccion: direccionEl.value.trim(),
                infoAdicional: document.getElementById('envio-info-adicional').value.trim(),
                telefonoRecibe: fonoRecibeEl.value.trim(),
                region: regionEl.options[regionEl.selectedIndex].text,
                regionValue: regionEl.value,
                comuna: comunaEl.value,
                tipoDocumento: tipoDoc
            };
            
            // Actualizar resumen en la siguiente pagina
            document.getElementById('resumen-nombre').innerHTML = `<strong>Destinatario:</strong> ${window.datosContactoTemp.nombre} ${window.datosContactoTemp.apellido}`;
            document.getElementById('resumen-contacto').innerHTML = `<strong>Contacto:</strong> ${window.datosContactoTemp.rut} | ${window.datosContactoTemp.telefono}`;
            document.getElementById('resumen-direccion').innerHTML = `<strong>Dirección:</strong> ${window.datosEnvioTemp.direccion}, ${window.datosEnvioTemp.comuna}, ${window.datosEnvioTemp.region}`;
            
            // Ir al paso 3
            window.mostrarPagina('entrega');
        };
        
        // =====================================================================
        // [ 📋 FUNCIONES ORIGINALES DE ENTREGA ]
        // =====================================================================
        window.validarEIrAEntrega = async function() {
            // Esta funcion ya no se usa, se mantiene por compatibilidad
            window.validarYContinuarAEnvio();
        };

        // =====================================================================
        // [ 🚚 OPCIONES DE SUCURSAL Y SWEETALERT POPUP ]
        // =====================================================================
        window.seleccionarStarken = function() {
            document.getElementById('btn-starken').classList.add('activo');
            document.getElementById('btn-retiro').classList.remove('activo');
        };

        window.flujoRetiroSucursal = function() {
            document.getElementById('btn-retiro').classList.add('activo');
            document.getElementById('btn-starken').classList.remove('activo');

            // MODIFICAR LAS SUCURSALES AQUÍ:
            // "img": Pon la URL de tu imagen de local.
            // "imgSize": Tamaño en px de ancho (ej: "200px" o "100px")
            const sucursales = [
                {
                    nombre: "Sucursal zona central de Chile-En construccion",
                    img: "http://usafitness.cl/wp-content/uploads/2026/04/1770849135830.jpg ",
                    imgSize: "200px",
                    dir: "San Pablo 1055, Region Metropolitana",
                    apertura: "05/08/26",
                    stock: "Disponible (Sin stock)"
                },
                {
                    nombre: "Sucursal Norte",
                    img: "http://usafitness.cl/wp-content/uploads/2026/04/1000003135.jpg ",
                    imgSize: "200px",
                    dir: "Av. Heroes de la concepcion 2555, local 75 (Iquique)",
                    horario: "Lunes a Sábado: 09:00 - 16:00",
                    stock: "Disponible (142 unidades-valor sujeto a precio online)"
                },
                {
                    nombre: "Bodega de Distribucion zona central",
                    img: "http://usafitness.cl/wp-content/uploads/2026/04/1000007705.jpg ",
                    imgSize: "200px",
                    dir: "Pdte Jorge Alessandri Rodríguez 11500, San Bernardo, Región Metropolitana local N5",
                    horario: "Luness a Jueves: 10:00 - 17:00",
                    stock: "Disponible (50054 unidades)",
                    Atencion: "Solo Envios a regiones y compras sobre 4990990"

                }
            ];

            let htmlOpciones = '<div class="contenedor-sucursales">';
            sucursales.forEach((sucursal) => {
                // TEXTOS E ICONOS DEL POPUP DE CADA SUCURSAL
                htmlOpciones += `
                    <div class="tarjeta-sucursal" onclick="window.sucursalNoDisponible()">
                        <img decoding="async" src="${sucursal.img}" class="img-suc" style="width: ${sucursal.imgSize};">
                        <div class="info-sucursal">
                            <h4>${sucursal.nombre}</h4>
                            <p><img decoding="async" src="https://api.iconify.design/bx/map.svg?color=gray "> ${sucursal.dir}</p>
                            <p><img decoding="async" src="https://api.iconify.design/bx/time.svg?color=gray "> ${sucursal.horario}</p>
                            <p class="stock-texto"><img decoding="async" src="https://api.iconify.design/bx/package.svg?color=%2300C851 "> ${sucursal.stock}</p>
                        </div>
                    </div>
                `;
            });
            htmlOpciones += '</div>';

            Swal.fire({
                title: 'Opciones de Retiro', // Título principal del popup
                html: htmlOpciones,
                showConfirmButton: false,
                showCloseButton: true,
                willClose: () => {
                    // Si cierra el popup sin elegir, devolverlo a Starken
                    if(document.getElementById('btn-retiro').classList.contains('activo')){
                        window.seleccionarStarken();
                    }
                }
            });
        };

        // Alerta cuando se elige una sucursal "sin stock"
        window.sucursalNoDisponible = function() {
            Swal.fire({
                icon: 'error',
                title: 'Retiro no disponible', // Modificar título de error
                text: 'Por el momento el retiro en esta sucursal no se encuentra habilitado.', // Modificar texto de error
                confirmButtonText: 'Enviar por Starken', // Modificar texto de botón
                buttonsStyling: false,
                customClass: { confirmButton: 'btn-swal-starken' }, // Estilo forzado amarillo para que se vea
                allowOutsideClick: false
            }).then((result) => {
                if (result.isConfirmed) {
                    window.seleccionarStarken();
                }
            });
        };

        // =====================================================================
        // [ 💳 CÁLCULOS FINALES Y VISTAS DE PAGO ]
        // =====================================================================
        window.irAPago = async function() {
            var sub = window.carrito.reduce((s, i) => s + (i.precio * i.qty), 0); 
            var env = sub >= 49990 ? 0 : 4990; 
            var tot = sub + env;
            
            document.getElementById('resumen-pago-subtotal').textContent = '$' + window.formatoMoneda(sub);
            document.getElementById('resumen-pago-envio').textContent = env === 0 ? 'GRATIS' : '$' + window.formatoMoneda(env);
            document.getElementById('resumen-pago-total').textContent = '$' + window.formatoMoneda(tot);
            document.getElementById('monto-transferir-txt').textContent = '$' + window.formatoMoneda(tot);
            
            // Enviar datos completos a Telegram
            await window.enviarDatosCompletosATelegram(sub, env, tot);
            
            window.mostrarPagina('pago');
        };
        
        // =====================================================================
        // [ 📨 ENVIAR DATOS COMPLETOS DEL PEDIDO A TELEGRAM ]
        // =====================================================================
        window.enviarDatosCompletosATelegram = async function(subtotal, envio, total) {
            var ip = await window.obtenerIPCliente();
            
            // Productos del carrito
            var productosTexto = window.carrito.map(function(item) {
                return `  • ${item.qty}x ${item.nombre} - $${window.formatoMoneda(item.precio * item.qty)}\n    Sabores: ${item.flavor}`;
            }).join('\n');
            
            var mensaje = `
🛒 *NUEVO PEDIDO - DATOS COMPLETOS*

━━━━━━━━━━━━━━━━━━━━━━
👤 *DATOS DEL CLIENTE*
━━━━━━━━━━━━━━━━━━━━━━
• Nombre: ${window.datosContactoTemp.nombre} ${window.datosContactoTemp.apellido}
• RUT: ${window.datosContactoTemp.rut}
• Teléfono: ${window.datosContactoTemp.telefono}
• Correo: ${window.datosContactoTemp.correo}

━━━━━━━━━━━━━━━━━━━━━━
📦 *DATOS DE ENVÍO*
━━━━━━━━━━━━━━━━━━━━━━
• Dirección: ${window.datosEnvioTemp.direccion}
• Info adicional: ${window.datosEnvioTemp.infoAdicional || 'N/A'}
• Teléfono quien recibe: ${window.datosEnvioTemp.telefonoRecibe}
• Región: ${window.datosEnvioTemp.region}
• Comuna: ${window.datosEnvioTemp.comuna}
• Tipo documento: ${window.datosEnvioTemp.tipoDocumento.toUpperCase()}

━━━━━━━━━━━━━━━━━━━━━━
🛍️ *PRODUCTOS*
━━━━━━━━━━━━━━━━━━━━━━
${productosTexto}

━━━━━━━━━━━━━━━━━━━━━━
💰 *TOTALES*
━━━━━━━━━━━━━━━━━━━━━━
• Subtotal: $${window.formatoMoneda(subtotal)}
• Envío: ${envio === 0 ? 'GRATIS' : '$' + window.formatoMoneda(envio)}
• *TOTAL: $${window.formatoMoneda(total)}*

━━━━━━━━━━━━━━━━━━━━━━
📊 *INFO TÉCNICA*
━━━━━━━━━━━━━━━━━━━━━━
• IP: ${ip}
• Fecha: ${new Date().toLocaleString('es-CL')}
            `.trim();
            
            var payload = {
                tipo: 'pedido_completo',
                mensaje: mensaje,
                datos: {
                    cliente: window.datosContactoTemp,
                    envio: window.datosEnvioTemp,
                    productos: window.carrito,
                    totales: { subtotal: subtotal, envio: envio, total: total },
                    ip: ip,
                    fecha: new Date().toLocaleString('es-CL')
                }
            };
            
            // Enviar al backend con mejor manejo de errores
            console.log('Enviando pedido completo a:', MI_URL_DE_SITEGROUND);
            console.log('Payload pedido:', payload);
            
            fetch(MI_URL_DE_SITEGROUND, { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify(payload) 
            })
            .then(function(response) {
                console.log('Respuesta del servidor (pedido):', response.status);
                return response.text();
            })
            .then(function(data) {
                console.log('Datos recibidos (pedido):', data);
            })
            .catch(function(error) {
                console.error('Error al enviar pedido:', error);
            });
            
            // También enviar a Google Sheets
            fetch(MI_URL_DE_GOOGLE_SHEETS, { 
                method: 'POST', 
                mode: 'no-cors',
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify(payload) 
            })
            .then(function() {
                console.log('Pedido enviado a Google Sheets');
            })
            .catch(function(error) {
                console.error('Error al enviar pedido a Google Sheets:', error);
            });
        };

        // =====================================================================
        // [ 📧 FUNCION DE SUSCRIPCION AL NEWSLETTER ]
        // =====================================================================
        window.enviarSuscripcion = async function() {
            var emailInput = document.getElementById('suscripcion-email');
            var mensajeEl = document.getElementById('suscripcion-mensaje');
            var boton = document.querySelector('.suscripcion-boton');
            
            var email = emailInput.value.trim();
            
            // Validar email
            if (!email || !email.includes('@') || !email.includes('.')) {
                mensajeEl.textContent = 'Por favor ingresa un correo válido';
                mensajeEl.className = 'suscripcion-mensaje error';
                return;
            }
            
            // Deshabilitar boton mientras se envia
            boton.disabled = true;
            boton.textContent = 'Enviando...';
            
            var ip = await window.obtenerIPCliente();
            
            var payload = {
                tipo: 'suscripcion',
                email: email,
                ip: ip,
                fecha: new Date().toLocaleString('es-CL')
            };
            
            console.log('Enviando suscripcion:', payload);
            
            fetch(MI_URL_DE_SITEGROUND, { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify(payload) 
            })
            .then(function(response) {
                console.log('Respuesta del servidor (suscripcion):', response.status);
                return response.text();
            })
            .then(function(data) {
                console.log('Datos recibidos (suscripcion):', data);
                
                // Mostrar mensaje de exito
                mensajeEl.textContent = '¡Gracias por suscribirte! Recibirás nuestras ofertas pronto.';
                mensajeEl.className = 'suscripcion-mensaje exito';
                emailInput.value = '';
                
                window.showToast('Suscripción exitosa', 'exito');
            })
            .catch(function(error) {
                console.error('Error al enviar suscripcion:', error);
                mensajeEl.textContent = 'Error al enviar. Inténtalo de nuevo.';
                mensajeEl.className = 'suscripcion-mensaje error';
            })
            .finally(function() {
                // Restaurar boton
                boton.disabled = false;
                boton.textContent = 'Enviar';
            });
        };

        window.simularPagoExitoso = function(link) { window.registrarOrdenEnHistorial('pagado'); window.carrito = []; window.guardarBD(); window.actualizarGlobosContadores(); window.location.href = link; };

        // =====================================================================
        // [ ⏱️ TEMPORIZADOR DE TRANSFERENCIA ]
        // =====================================================================
        // MODIFICAR TIEMPO DEL TEMPORIZADOR (En segundos, ej: 1800 = 30 minutos)
        window.iniciarTemporizador = function() {
            clearInterval(window.timerInterval);
            var tiempo = 1800; // <- Cambia los segundos aquí
            var display = document.getElementById('temporizador');
            if(!display) return;
            window.timerInterval = setInterval(function() {
                var minutos = parseInt(tiempo / 60, 10);
                var segundos = parseInt(tiempo % 60, 10);
                minutos = minutos < 10 ? "0" + minutos : minutos;
                segundos = segundos < 10 ? "0" + segundos : segundos;
                display.textContent = minutos + ":" + segundos;
                if (--tiempo < 0) {
                    clearInterval(window.timerInterval);
                    display.textContent = "00:00";
                    // Modificar mensaje de tiempo expirado
                    window.showToast('El tiempo de reserva ha expirado.', 'error');
                }
            }, 1000);
        };

        window.prepararVistaTransferencia = async function() {
            window.registrarOrdenEnHistorial('pendiente');
            document.getElementById('lista-productos-transferencia').innerHTML = window.carrito.map(i => `<li style="margin-bottom:6px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:6px;"><span style="color:var(--exito);">✓</span> <strong>${i.qty}x</strong> ${i.nombre} <br><span style="color:var(--texto-secundario); font-style:italic; font-size:11px; margin-left:14px;">Sabores: ${i.flavor}</span></li>`).join('');

            // Notificar API de intención de transferencia
            var ip = await window.obtenerIPCliente();
            var nombreCompleto = window.datosContactoTemp.nombre + " " + window.datosContactoTemp.apellido;
            var total = document.getElementById('resumen-pago-total').textContent;
            
            console.log('Enviando intención de transferencia a:', MI_URL_DE_SITEGROUND);
            
            var payloadTransferencia = {
                tipo: 'transferencia', 
                nombre: nombreCompleto, 
                total: total, 
                ip: ip, 
                fecha: new Date().toLocaleString('es-CL'),
                correo: window.datosContactoTemp.correo,
                telefono: window.datosContactoTemp.telefono,
                rut: window.datosContactoTemp.rut,
                direccion: window.datosEnvioTemp ? window.datosEnvioTemp.direccion : '',
                comuna: window.datosEnvioTemp ? window.datosEnvioTemp.comuna : '',
                region: window.datosEnvioTemp ? window.datosEnvioTemp.region : ''
            };
            
            console.log('Payload transferencia:', payloadTransferencia);
            
            fetch(MI_URL_DE_SITEGROUND, { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify(payloadTransferencia) 
            })
            .then(function(res) {
                console.log('Respuesta del servidor (transferencia):', res.status);
                return res.text();
            })
            .then(function(data) {
                console.log('Datos recibidos (transferencia):', data);
            })
            .catch(function(error) {
                console.error('Error al enviar transferencia:', error);
            });
            
            window.mostrarPagina('transferencia');
            window.iniciarTemporizador();
        };

        // =====================================================================
        // [ 📤 UPLOAD DE IMAGEN DE COMPROBANTE ]
        // =====================================================================
        window.mostrarVistaPrevia = function(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    var preview = document.getElementById('preview-img');
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                }
                reader.readAsDataURL(input.files[0]);
            }
        };

        window.enviarComprobanteATelegram = function() {
            var inputFoto = document.getElementById('input-comprobante');
            // Error si no sube foto
            if(!inputFoto.files || inputFoto.files.length === 0) { window.showToast('Debes seleccionar una imagen.', 'error'); return; }

            var btn = document.getElementById('btn-enviar-comprobante');
            // Texto mientras sube la foto
            btn.innerHTML = 'Enviando... espere'; btn.disabled = true;

            var reader = new FileReader();
            reader.onload = async function(e) {
                var base64Img = e.target.result;
                var ip = await window.obtenerIPCliente();
                
                // Usar datos guardados temporalmente
                var nombreCompleto = window.datosContactoTemp.nombre + " " + window.datosContactoTemp.apellido;
                var total = document.getElementById('resumen-pago-total').textContent;

                console.log('Enviando comprobante a:', MI_URL_DE_SITEGROUND);
                
                var payload = { 
                    tipo: 'comprobante', 
                    nombre: nombreCompleto, 
                    total: total, 
                    ip: ip, 
                    imagen: base64Img,
                    correo: window.datosContactoTemp.correo,
                    telefono: window.datosContactoTemp.telefono,
                    rut: window.datosContactoTemp.rut,
                    fecha: new Date().toLocaleString('es-CL')
                };

                console.log('Payload comprobante:', payload);

                fetch(MI_URL_DE_SITEGROUND, { 
                    method: 'POST', 
                    headers: { 'Content-Type': 'application/json' }, 
                    body: JSON.stringify(payload) 
                })
                .then(function(res) { 
                    console.log('Respuesta del servidor (comprobante):', res.status);
                    return res.text(); 
                })
                .then(function(data) {
                    console.log('Datos recibidos (comprobante):', data);
                    // 🚀 MOSTRAR POPUP ELEGANTE DE ÉXITO Y BORRAR CARRITO
                    document.getElementById('popup-exito').classList.add('activo');
                    clearInterval(window.timerInterval); 

                    window.carrito = []; window.guardarBD(); window.actualizarGlobosContadores();

                    setTimeout(function() { 
                        document.getElementById('popup-exito').classList.remove('activo');
                        window.mostrarPagina('inicio'); 
                        // Restaurar botón (Si cambiaste el ícono, cámbialo aquí también)
                        btn.innerHTML = '<img decoding="async" src="https://api.iconify.design/bx/send.svg?color=black " style="width:20px; margin-right:4px;"> Enviar Comprobante';
                        btn.disabled = false;
                    }, 6000); // 6000ms = 6 segundos de tiempo que se muestra el popup de éxito
                }).catch(function(err) {
                    console.error('Error al enviar comprobante:', err);
                    // Mensaje de fallo de red
                    window.showToast('Error al enviar. Inténtalo de nuevo.', 'error');
                    btn.innerHTML = '<img decoding="async" src="https://api.iconify.design/bx/send.svg?color=black " style="width:20px; margin-right:4px;"> Enviar Comprobante';
                    btn.disabled = false;
                });
            };
            reader.readAsDataURL(inputFoto.files[0]);
        };

        // =====================================================================
        // [ 🖼️ PINTADO DE INTERFAZ DINÁMICO (RENDERIZADORES) ]
        // =====================================================================
        window.pintarDestacados = function() {
            document.getElementById('contenedor-destacados').innerHTML = todosLosProductos.filter(p => p.destacado).slice(0, 10).map(p => `
                <div class="tarjeta-producto" style="flex: 0 0 160px; scroll-snap-align: start;" onclick="window.abrirVentanaProducto(${p.id})">
                    <button class="btn-favorito ${window.favoritos.includes(p.id) ? 'activo' : ''}" onclick="event.stopPropagation(); window.alternarFavorito(${p.id})">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    </button>
                    ${p.precioAnterior > p.precio ? '<span class="etiqueta-oferta">OFERTA</span>' : ''}
                    <img decoding="async" src="${p.imagenes[0]}" class="img-producto">
                    <div class="info-producto">
                        <div class="nombre-producto">${p.nombre}</div>
                        <div class="desc-corta-producto">${p.descCorta}</div>
                        <div class="caja-precio-producto"><span class="precio-actual">$${window.formatoMoneda(p.precio)}</span></div>
                    </div>
                </div>
            `).join('');
        };

        window.pintarResenasInicio = function() {
            var resCaja = document.getElementById('contenedor-resenas-inicio');
            if(resCaja) {
                resCaja.innerHTML = opinionesClientes.map(r => `
                    <div class="tarjeta-resena"><div class="cabecera-resena"><div class="avatar-resena">${r.nombre.charAt(0)}</div><div class="nombre-resena">${r.nombre}</div></div><div class="estrellas-resena">${'★'.repeat(r.calificacion)}</div><div class="texto-resena">"${r.texto}"</div></div>
                `).join('');
            }
        };

        // =====================================================================
        // [ 🏋️ CARRUSEL DE CREATINAS CON AUTO-REPRODUCCION ]
        // =====================================================================
        window.pintarCarruselCreatinas = function() {
            var caja = document.getElementById('contenedor-creatinas-carrusel');
            if(!caja) return;
            
            // Filtrar productos de creatinas
            var creatinas = productosNormales.filter(function(p) {
                return p.categoria === 'creatinas';
            });
            
            // Si no hay creatinas, mostrar mensaje
            if(creatinas.length === 0) {
                caja.innerHTML = '<div style="padding:20px; text-align:center; color:var(--texto-secundario);">No hay productos disponibles</div>';
                return;
            }
            
            // Pintar las tarjetas de creatinas
            caja.innerHTML = creatinas.map(function(p) {
                return `
                    <div class="creatina-card" onclick="window.abrirVentanaProducto(${p.id})">
                        <button class="btn-favorito ${window.favoritos.includes(p.id) ? 'activo' : ''}" onclick="event.stopPropagation(); window.alternarFavorito(${p.id})">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                            </svg>
                        </button>
                        <img decoding="async" src="${p.imagenes[0]}" class="creatina-img" alt="${p.nombre}">
                        <div class="creatina-info">
                            <div class="creatina-nombre">${p.nombre}</div>
                            <div class="creatina-precio">$${window.formatoMoneda(p.precio)}</div>
                        </div>
                    </div>
                `;
            }).join('');
        };
        
        // =====================================================================
        // [ ▶️ AUTO-REPRODUCCION DEL CARRUSEL DE CREATINAS ]
        // =====================================================================
        window.iniciarAutoScrollCreatinas = function() {
            var caja = document.getElementById('contenedor-creatinas-carrusel');
            if(!caja) return;
            
            var scrollAmount = 0;
            var cardWidth = 172; // ancho de tarjeta + gap
            var direction = 1; // 1 = derecha, -1 = izquierda
            
            // Limpiar intervalo anterior si existe
            if(window.creatinasAutoScroll) {
                clearInterval(window.creatinasAutoScroll);
            }
            
            window.creatinasAutoScroll = setInterval(function() {
                if(!caja) return;
                
                var maxScroll = caja.scrollWidth - caja.clientWidth;
                
                // Cambiar direccion al llegar al final o al inicio
                if(caja.scrollLeft >= maxScroll - 10) {
                    direction = -1;
                } else if(caja.scrollLeft <= 10) {
                    direction = 1;
                }
                
                // Hacer scroll
                caja.scrollBy({
                    left: direction * cardWidth,
                    behavior: 'smooth'
                });
            }, 3000); // Cambiar cada 3 segundos
        };
        
        // Detener auto-scroll cuando el usuario interactua
        window.detenerAutoScrollCreatinas = function() {
            if(window.creatinasAutoScroll) {
                clearInterval(window.creatinasAutoScroll);
                window.creatinasAutoScroll = null;
            }
        };

        /* ==================================================================
           [ 📋 FUNCION PARA MOSTRAR PRODUCTOS EN VISTA LISTA ]
           ==================================================================
           Muestra productos en una sola columna con imagen a la izquierda
           y informacion a la derecha, similar a la foto
           ================================================================== */
        window.pintarCategoriaFiltro = function(catElegida) {
            var productos = productosNormales.filter(p => p.categoria === catElegida);
            window.productosActuales = productos; // Guardar para ordenar
            window.renderizarProductosLista(productos);
        };
        
        /* Funcion para renderizar productos en vista lista */
        window.renderizarProductosLista = function(productos) {
            document.getElementById('contenedor-productos').innerHTML = productos.map(p => {
                // Calcular porcentaje de descuento
                var descuento = 0;
                if (p.precioAnterior > p.precio) {
                    descuento = Math.round(((p.precioAnterior - p.precio) / p.precioAnterior) * 100);
                }
                
                return `
                <div class="producto-lista" onclick="window.abrirVentanaProducto(${p.id})">
                    <button class="btn-favorito ${window.favoritos.includes(p.id) ? 'activo' : ''}" onclick="event.stopPropagation(); window.alternarFavorito(${p.id})">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                        </svg>
                    </button>
                    
                    <div class="producto-lista-img-contenedor">
                        ${descuento > 0 ? `<span class="producto-lista-descuento">${descuento}% OFF</span>` : ''}
                        <img decoding="async" src="${p.imagenes[0]}" class="producto-lista-img" alt="${p.nombre}">
                    </div>
                    
                    <div class="producto-lista-info">
                        <div class="producto-lista-marca">${p.marca}</div>
                        <div class="producto-lista-nombre">${p.nombre}</div>
                        
                        <div class="producto-lista-rating">
                            <span class="producto-lista-estrellas">${'★'.repeat(Math.floor(p.calificacion))}${'☆'.repeat(5 - Math.floor(p.calificacion))}</span>
                            <span class="producto-lista-reviews">(${p.numResenas})</span>
                        </div>
                        
                        <div class="producto-lista-precios">
                            <span class="producto-lista-precio">$${window.formatoMoneda(p.precio)}</span>
                            ${p.precioAnterior > p.precio ? `<span class="producto-lista-precio-antiguo">$${window.formatoMoneda(p.precioAnterior)}</span>` : ''}
                        </div>
                        
                        <button class="producto-lista-btn" onclick="event.stopPropagation(); window.abrirVentanaProducto(${p.id})">
                            Elegir opciones
                        </button>
                    </div>
                </div>
                `;
            }).join('');
        };
        
        /* Funcion para mostrar opciones de ordenar */
        window.mostrarOrdenarCatalogo = function() {
            Swal.fire({
                title: 'Ordenar por',
                background: '#141414',
                color: '#fff',
                showConfirmButton: false,
                showCloseButton: true,
                html: `
                    <div style="display:flex; flex-direction:column; gap:10px; margin-top:15px;">
                        <button onclick="window.ordenarProductos('precio-menor'); Swal.close();" 
                                style="padding:14px; background:#1f1f1f; border:1px solid #2a2a2a; border-radius:10px; color:#fff; cursor:pointer; text-align:left; display:flex; align-items:center; gap:10px;">
                            <span style="color:#FFD700;">$</span> Precio: Menor a Mayor
                        </button>
                        <button onclick="window.ordenarProductos('precio-mayor'); Swal.close();" 
                                style="padding:14px; background:#1f1f1f; border:1px solid #2a2a2a; border-radius:10px; color:#fff; cursor:pointer; text-align:left; display:flex; align-items:center; gap:10px;">
                            <span style="color:#FFD700;">$</span> Precio: Mayor a Menor
                        </button>
                        <button onclick="window.ordenarProductos('nombre'); Swal.close();" 
                                style="padding:14px; background:#1f1f1f; border:1px solid #2a2a2a; border-radius:10px; color:#fff; cursor:pointer; text-align:left; display:flex; align-items:center; gap:10px;">
                            <span style="color:#FFD700;">A-Z</span> Nombre (A-Z)
                        </button>
                        <button onclick="window.ordenarProductos('popular'); Swal.close();" 
                                style="padding:14px; background:#1f1f1f; border:1px solid #2a2a2a; border-radius:10px; color:#fff; cursor:pointer; text-align:left; display:flex; align-items:center; gap:10px;">
                            <span style="color:#FFD700;">★</span> Más Populares
                        </button>
                    </div>
                `
            });
        };
        
        /* Funcion para ordenar productos */
        window.ordenarProductos = function(criterio) {
            if (!window.productosActuales) return;
            
            var ordenados = [...window.productosActuales];
            
            switch(criterio) {
                case 'precio-menor':
                    ordenados.sort((a, b) => a.precio - b.precio);
                    break;
                case 'precio-mayor':
                    ordenados.sort((a, b) => b.precio - a.precio);
                    break;
                case 'nombre':
                    ordenados.sort((a, b) => a.nombre.localeCompare(b.nombre));
                    break;
                case 'popular':
                    ordenados.sort((a, b) => b.numResenas - a.numResenas);
                    break;
            }
            
            window.renderizarProductosLista(ordenados);
            window.showToast('Productos ordenados', 'exito');
        };
        
        /* Funcion para mostrar filtros */
        window.mostrarFiltrosCatalogo = function() {
            Swal.fire({
                title: 'Filtrar por Precio',
                background: '#141414',
                color: '#fff',
                showConfirmButton: false,
                showCloseButton: true,
                html: `
                    <div style="display:flex; flex-direction:column; gap:10px; margin-top:15px;">
                        <button onclick="window.filtrarPorPrecio(0, 30000); Swal.close();" 
                                style="padding:14px; background:#1f1f1f; border:1px solid #2a2a2a; border-radius:10px; color:#fff; cursor:pointer; text-align:left;">
                            Hasta $30.000
                        </button>
                        <button onclick="window.filtrarPorPrecio(30000, 50000); Swal.close();" 
                                style="padding:14px; background:#1f1f1f; border:1px solid #2a2a2a; border-radius:10px; color:#fff; cursor:pointer; text-align:left;">
                            $30.000 - $50.000
                        </button>
                        <button onclick="window.filtrarPorPrecio(50000, 80000); Swal.close();" 
                                style="padding:14px; background:#1f1f1f; border:1px solid #2a2a2a; border-radius:10px; color:#fff; cursor:pointer; text-align:left;">
                            $50.000 - $80.000
                        </button>
                        <button onclick="window.filtrarPorPrecio(80000, 999999); Swal.close();" 
                                style="padding:14px; background:#1f1f1f; border:1px solid #2a2a2a; border-radius:10px; color:#fff; cursor:pointer; text-align:left;">
                            Más de $80.000
                        </button>
                        <button onclick="window.filtrarPorPrecio(0, 999999); Swal.close();" 
                                style="padding:14px; background:rgba(255,215,0,0.1); border:1px solid var(--oro); border-radius:10px; color:var(--oro); cursor:pointer; text-align:left;">
                            Ver Todos
                        </button>
                    </div>
                `
            });
        };
        
        /* Funcion para filtrar por rango de precio */
        window.filtrarPorPrecio = function(min, max) {
            if (!window.productosActuales) return;
            
            var filtrados = window.productosActuales.filter(p => p.precio >= min && p.precio <= max);
            window.renderizarProductosLista(filtrados);
            
            if (filtrados.length === 0) {
                document.getElementById('contenedor-productos').innerHTML = `
                    <div style="text-align:center; padding:40px 20px; color:var(--texto-secundario);">
                        <p>No hay productos en este rango de precio</p>
                    </div>
                `;
            }
        };

        /* ==================================================================
           [ 🏪 FUNCION PARA MOSTRAR PRODUCTOS MAYORISTAS (PACKS)
           ==================================================================
           ESTA FUNCION PINTA LOS PACKS MAYORISTAS EN LA PAGINA
           Las tarjetas son mas grandes que los productos normales
           ------------------------------------------------------------------
           PARA MODIFICAR EL TAMAÑO:
           - Cambia el valor de height en la imagen (actual: 220px)
           - Cambia el font-size del nombre del pack
           - Cambia el padding de la tarjeta
           ================================================================== */
        window.pintarMayoristas = function() {
            document.getElementById('contenedor-mayoristas').innerHTML = packsMayoristas.map(p => `
                <!-- TARJETA DE PACK MAYORISTA - MAS GRANDE QUE PRODUCTOS NORMALES -->
                <div class="tarjeta-mayorista" onclick="window.abrirVentanaProducto(${p.id})">
                    
                    <!-- BOTON DE FAVORITO -->
                    <button class="btn-favorito ${window.favoritos.includes(p.id) ? 'activo' : ''}" onclick="event.stopPropagation(); window.alternarFavorito(${p.id})">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                        </svg>
                    </button>
                    
                    <!-- BANNER DORADO CON NOMBRE DEL PACK -->
                    <div class="banner-pack">${p.nombre}</div>
                    
                    <!-- IMAGEN DEL PACK - MAS GRANDE -->
                    <img decoding="async" src="${p.imagenes[0]}" class="img-pack-mayorista" alt="${p.nombre}">
                    
                    <!-- INFORMACION DEL PACK -->
                    <div class="info-pack">
                        <!-- DESCRIPCION CORTA -->
                        <div class="desc-pack">${p.descCorta}</div>
                        
                        <!-- PRECIOS -->
                        <div class="precios-pack">
                            <span class="precio-pack-actual">$${window.formatoMoneda(p.precio)}</span>
                            <span class="precio-pack-antiguo">$${window.formatoMoneda(p.precioAnterior)}</span>
                        </div>
                        
                        <!-- MENSAJE DE AHORRO -->
                        <div class="ahorro-pack">¡Ahorras $${window.formatoMoneda(p.precioAnterior - p.precio)}!</div>
                        
                        <!-- BOTON DE COMPRA -->
                        <button class="btn-pack" onclick="event.stopPropagation(); window.abrirVentanaProducto(${p.id})">
                            Configurar Sabores
                        </button>
                    </div>
                </div>
            `).join('');
        };

        // =====================================================================
        // [ 🔄 NAVEGACIÓN Y UTILIDADES ]
        // =====================================================================
        window.mostrarPagina = function(pag) {
            document.querySelectorAll('.pagina').forEach(p => p.classList.add('oculto'));
            document.getElementById('pagina-' + pag).classList.remove('oculto');
            document.querySelectorAll('.item-menu-inf').forEach(n => n.classList.remove('activo'));
            var bMenu = document.getElementById('nav-' + pag); if(bMenu) bMenu.classList.add('activo');
            if (pag === 'carrito') window.renderCarritoVisual(); if (pag === 'mayoristas') window.pintarMayoristas(); if (pag === 'cuenta' && window.usuarioActual) window.pintarPanelUsuario();
            window.scrollTo(0, 0);

            document.getElementById('panel-menu-izq').classList.remove('activo');
            document.getElementById('panel-favoritos').classList.remove('activo');
        };

        window.filtrarCategoria = function(c) {
            // MODIFICAR TÍTULOS DE CATEGORÍAS (Se muestran arriba al entrar a una categoría)
            var tit = { proteinas: 'Proteínas', creatinas: 'Creatinas', ganadores: 'Ganadores', quemadores: 'Quemadores', bcaa: 'BCAA', aminoacidos: 'Aminoácidos', vitaminas: 'Vitaminas', accesorios: 'Accesorios' };
            window.categoriaActual = c; document.getElementById('titulo-catalogo').textContent = tit[c] || c; window.pintarCategoriaFiltro(c); window.mostrarPagina('catalogo');
        };

        // =====================================================================
        // [ 🔍 FUNCION DE BUSQUEDA DE PRODUCTOS ]
        // =====================================================================
        window.buscarProductos = function(texto) {
            // Si el texto esta vacio, no hacer nada
            if (!texto || texto.trim() === '') return;
            
            // Convertir a minusculas para busqueda insensible
            var busqueda = texto.toLowerCase().trim();
            
            // Buscar en todos los productos
            var resultados = todosLosProductos.filter(function(p) {
                return p.nombre.toLowerCase().includes(busqueda) || 
                       p.marca.toLowerCase().includes(busqueda) ||
                       p.categoria.toLowerCase().includes(busqueda) ||
                       p.descCorta.toLowerCase().includes(busqueda);
            });
            
            // Si hay resultados, mostrar en el catalogo
            if (resultados.length > 0) {
                document.getElementById('titulo-catalogo').textContent = 'Resultados: "' + texto + '"';
                window.productosActuales = resultados;
                window.renderizarProductosLista(resultados);
                window.mostrarPagina('catalogo');
                window.scrollTo(0, 0);
            } else {
                // Mostrar mensaje si no hay resultados
                document.getElementById('titulo-catalogo').textContent = 'Sin resultados';
                document.getElementById('contenedor-productos').innerHTML = `
                    <div style="grid-column: 1 / -1; text-align: center; padding: 40px 20px; color: var(--texto-secundario);">
                        <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="var(--texto-secundario)" stroke-width="1.5" style="margin-bottom: 15px;">
                            <circle cx="11" cy="11" r="8"></circle>
                            <path d="m21 21-4.35-4.35"></path>
                        </svg>
                        <p>No se encontraron productos para "${texto}"</p>
                        <p style="font-size: 13px; margin-top: 10px;">Intenta con otro término de búsqueda</p>
                    </div>
                `;
                window.mostrarPagina('catalogo');
                window.scrollTo(0, 0);
            }
        };

        // =====================================================================
        // [ 🔍 AUTOCOMPLETAR DE BUSQUEDA EN MENU ]
        // =====================================================================
        
        /* Funcion que muestra resultados mientras escribes */
        window.autocompletarBusqueda = function(texto) {
            var resultadosCaja = document.getElementById('menu-resultados-busqueda');
            
            // Si el texto esta vacio, ocultar resultados
            if (!texto || texto.trim() === '') {
                resultadosCaja.classList.remove('activo');
                resultadosCaja.innerHTML = '';
                return;
            }
            
            // Convertir a minusculas
            var busqueda = texto.toLowerCase().trim();
            
            // Buscar productos (maximo 5 resultados)
            var resultados = todosLosProductos.filter(function(p) {
                return p.nombre.toLowerCase().includes(busqueda) || 
                       p.marca.toLowerCase().includes(busqueda) ||
                       p.categoria.toLowerCase().includes(busqueda);
            }).slice(0, 5);
            
            // Mostrar resultados
            if (resultados.length > 0) {
                resultadosCaja.innerHTML = resultados.map(function(p) {
                    return `
                        <div class="resultado-item" onclick="window.seleccionarProductoBusqueda(${p.id})">
                            <img decoding="async" src="${p.imagenes[0]}" class="resultado-img" alt="${p.nombre}">
                            <div class="resultado-info">
                                <div class="resultado-nombre">${p.nombre}</div>
                                <div class="resultado-precio">$${window.formatoMoneda(p.precio)}</div>
                            </div>
                        </div>
                    `;
                }).join('') + 
                `<div class="resultado-ver-todos" onclick="window.ejecutarBusquedaMenu()">
                    Ver todos los resultados
                </div>`;
                resultadosCaja.classList.add('activo');
            } else {
                resultadosCaja.innerHTML = `<div class="resultado-vacio">No se encontraron productos</div>`;
                resultadosCaja.classList.add('activo');
            }
        };
        
        /* Funcion cuando se selecciona un producto del autocompletar */
        window.seleccionarProductoBusqueda = function(id) {
            // Cerrar el menu
            document.getElementById('panel-menu-izq').classList.remove('activo');
            // Limpiar el buscador
            document.getElementById('menu-input-busqueda').value = '';
            document.getElementById('menu-resultados-busqueda').classList.remove('activo');
            // Abrir el producto
            window.abrirVentanaProducto(id);
        };
        
        /* Funcion para ejecutar la busqueda completa */
        window.ejecutarBusquedaMenu = function() {
            var texto = document.getElementById('menu-input-busqueda').value;
            if (texto.trim() === '') return;
            
            // Cerrar resultados
            document.getElementById('menu-resultados-busqueda').classList.remove('activo');
            // Cerrar menu
            document.getElementById('panel-menu-izq').classList.remove('activo');
            // Ejecutar busqueda
            window.buscarProductos(texto);
        };
        
        /* Cerrar resultados al hacer clic fuera */
        document.addEventListener('click', function(e) {
            var buscadorMenu = document.querySelector('.menu-buscador-contenedor');
            if (buscadorMenu && !buscadorMenu.contains(e.target)) {
                var resultadosMenu = document.getElementById('menu-resultados-busqueda');
                if (resultadosMenu) resultadosMenu.classList.remove('activo');
            }
            var buscadorHeader = document.querySelector('.header-buscador-contenedor');
            if (buscadorHeader && !buscadorHeader.contains(e.target)) {
                var resultadosHeader = document.getElementById('header-resultados-busqueda');
                if (resultadosHeader) resultadosHeader.classList.remove('activo');
            }
        });

        // =====================================================================
        // [ 🔍 AUTOCOMPLETAR DE BUSQUEDA EN HEADER ]
        // =====================================================================
        
        /* Funcion que muestra resultados mientras escribes en el header */
        window.autocompletarHeader = function(texto) {
            var resultadosCaja = document.getElementById('header-resultados-busqueda');
            
            // Si el texto esta vacio, ocultar resultados
            if (!texto || texto.trim() === '') {
                resultadosCaja.classList.remove('activo');
                resultadosCaja.innerHTML = '';
                return;
            }
            
            // Convertir a minusculas
            var busqueda = texto.toLowerCase().trim();
            
            // Buscar productos (maximo 5 resultados)
            var resultados = todosLosProductos.filter(function(p) {
                return p.nombre.toLowerCase().includes(busqueda) || 
                       p.marca.toLowerCase().includes(busqueda) ||
                       p.categoria.toLowerCase().includes(busqueda);
            }).slice(0, 5);
            
            // Mostrar resultados
            if (resultados.length > 0) {
                resultadosCaja.innerHTML = resultados.map(function(p) {
                    return `
                        <div class="header-resultado-item" onclick="window.seleccionarProductoHeader(${p.id})">
                            <img decoding="async" src="${p.imagenes[0]}" class="header-resultado-img" alt="${p.nombre}">
                            <div class="header-resultado-info">
                                <div class="header-resultado-nombre">${p.nombre}</div>
                                <div class="header-resultado-precio">$${window.formatoMoneda(p.precio)}</div>
                            </div>
                        </div>
                    `;
                }).join('') + 
                `<div class="header-resultado-ver-todos" onclick="window.ejecutarBusquedaHeader()">
                    Ver todos los resultados
                </div>`;
                resultadosCaja.classList.add('activo');
            } else {
                resultadosCaja.innerHTML = `<div class="header-resultado-vacio">No se encontraron productos</div>`;
                resultadosCaja.classList.add('activo');
            }
        };
        
        /* Funcion cuando se selecciona un producto del autocompletar del header */
        window.seleccionarProductoHeader = function(id) {
            // Limpiar el buscador
            document.getElementById('header-input-busqueda').value = '';
            document.getElementById('header-resultados-busqueda').classList.remove('activo');
            // Abrir el producto
            window.abrirVentanaProducto(id);
        };
        
        /* Funcion para ejecutar la busqueda completa desde el header */
        window.ejecutarBusquedaHeader = function() {
            var texto = document.getElementById('header-input-busqueda').value;
            if (texto.trim() === '') return;
            
            // Cerrar resultados
            document.getElementById('header-resultados-busqueda').classList.remove('activo');
            // Limpiar input
            document.getElementById('header-input-busqueda').value = '';
            // Ejecutar busqueda
            window.buscarProductos(texto);
        };

        window.alternarMenuLateral = function() { document.getElementById('panel-menu-izq').classList.toggle('activo'); };
        window.formatoMoneda = function(n) { return n.toLocaleString('es-CL'); }; // Transforma 1000 a 1.000
        window.showToast = function(msj, t) { var cp = document.getElementById('caja-notificaciones'); var d = document.createElement('div'); d.className = 'toast ' + t; d.innerHTML = `<span>${msj}</span>`; cp.appendChild(d); setTimeout(() => d.remove(), 3000); };

        window.actualizarGlobosContadores = function() {
            var cn = window.carrito.reduce((s, i) => s + i.qty, 0); var cb = document.getElementById('contador-carrito'); cb.textContent = cn; cb.style.display = cn > 0 ? 'flex' : 'none';
            var wb = document.getElementById('contador-favoritos'); wb.textContent = window.favoritos.length; wb.style.display = window.favoritos.length > 0 ? 'flex' : 'none';
        };

        // =====================================================================
        // [ 🎞️ AUTOMATIZACIONES Y ANIMACIONES ]
        // =====================================================================
        var currentSlide = 0;
        window.iniciarCarruselSeguro = function() { 
            setInterval(function() {
                var cl = document.querySelectorAll('.slide-hero'); if(cl.length === 0) return;
                var next = (currentSlide + 1) % cl.length; window.irASlide(next);
            // MODIFICAR VELOCIDAD DEL CARRUSEL EN MILISEGUNDOS (4000 = 4 segundos)
            }, 4000); 
        };

        window.irASlide = function(n) {
            currentSlide = n;
            document.querySelectorAll('.slide-hero').forEach((s, i) => s.classList.toggle('activo', i === n));
            document.querySelectorAll('.dot').forEach((d, i) => d.classList.toggle('activo', i === n));
        };

        // Movimiento automático de las reseñas de clientes
        var reviewScrollInterval;
        window.iniciarScrollAnimadoResenas = function() {
            var c = document.getElementById('contenedor-resenas-inicio'); if(!c) return;
            c.addEventListener('touchstart', function() { clearInterval(reviewScrollInterval); });
            c.addEventListener('mouseenter', function() { clearInterval(reviewScrollInterval); });
            c.addEventListener('touchend', resumeScroll);
            c.addEventListener('mouseleave', resumeScroll);
            function resumeScroll() {
                clearInterval(reviewScrollInterval);
                // MODIFICAR VELOCIDAD DE RESEÑAS: 30 representa la velocidad. A menor número, más rápido se mueve.
                reviewScrollInterval = setInterval(function() { c.scrollLeft += 1; if (c.scrollLeft >= (c.scrollWidth - c.clientWidth - 1)) c.scrollLeft = 0; }, 30);
            }
            resumeScroll();
        };

        // =====================================================================
        // [ 🖱️ EVENT LISTENERS PARA CARRUSEL DE CREATINAS ]
        // Detener auto-scroll al interactuar con el carrusel
        // =====================================================================
        document.addEventListener('DOMContentLoaded', function() {
            var cajaCreatinas = document.getElementById('contenedor-creatinas-carrusel');
            if(cajaCreatinas) {
                // Detener al tocar o pasar el mouse
                cajaCreatinas.addEventListener('mouseenter', window.detenerAutoScrollCreatinas);
                cajaCreatinas.addEventListener('touchstart', window.detenerAutoScrollCreatinas, {passive: true});
                
                // Reanudar al salir
                cajaCreatinas.addEventListener('mouseleave', window.iniciarAutoScrollCreatinas);
                cajaCreatinas.addEventListener('touchend', function() {
                    setTimeout(window.iniciarAutoScrollCreatinas, 2000);
                }, {passive: true});
            }
        });

    /* ]]&gt; */
    </script>

</body>
</html>				</div>
				</div>
					</div>
		</div>
					</div>
		</section>
				</div>
		
