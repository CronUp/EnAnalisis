<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

    <title>USA Fitness - Tienda de Suplementos Mayorista</title>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11 "></script>

    <style>
        /* ====================================================================== 
           [ 🎨 COLORES GLOBALES DEL SITIO ]
           Modifica los códigos Hexadecimales (ej: #0a0a0a) para cambiar los colores de toda la tienda.
           ====================================================================== */
        #usa-app {
            --fondo: #0a0a0a;             /* Color de fondo principal (negro oscuro) */
            --card: #141414;              /* Color de fondo de las tarjetas y menú lateral (gris muy oscuro) */
            --card-light: #1f1f1f;        /* Color para fondos secundarios y hover (gris) */
            --oro: #FFD700;               /* Color de los botones principales y detalles (Amarillo/Oro) */
            --texto: #ffffff;             /* Color del texto principal (Blanco) */
            --texto-secundario: #b0b0b0;  /* Color del texto secundario o descriptivo (Gris claro) */
            --borde: #2a2a2a;             /* Color de las líneas y bordes divisorios */
            --exito: #00C851;             /* Color para mensajes de éxito (Verde) */
            --error: #ff4444;             /* Color para errores o alertas (Rojo) */

            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; 
            background: var(--fondo); color: var(--texto);
            max-width: 430px; margin: 0 auto; min-height: 100vh;
            padding-bottom: 70px; position: relative; overflow-x: hidden; scroll-behavior: smooth;
        }

        /* Reset de márgenes (NO MODIFICAR) */
        #usa-app * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        #usa-app .oculto { display: none !important; }
        #usa-app .btn-icono img, #usa-app .item-menu-inf img, #usa-app .menu-lateral a img, #usa-app .btn-menu span { pointer-events: none; }

        /* ====================================================================== 
           [ 📱 HEADER (Barra Superior) ]
           ==================================================================
           BARRA FIJA EN LA PARTE SUPERIOR DE LA PANTALLA
           Contiene: Menu hamburguesa, Logo, Iconos (cuenta, favoritos, carrito)
           ------------------------------------------------------------------
           - barra-superior: Contenedor principal fijo en la parte de arriba
           - btn-menu: Boton de 3 lineas para abrir el menu lateral
           - contenedor-logo: Logo centrado de USA Fitness
           - iconos-derecha: Contenedor de iconos (usuario, corazon, carrito)
           - btn-icono: Cada boton circular de icono
           - globo-contador: Circulo amarillo con numero de items
           ================================================================== */
        
        /* Barra superior fija */
        #usa-app .barra-superior { 
            /* Posicion fija */
            position: fixed; 
            top: 0; 
            left: 50%; 
            /* Centrado horizontal */
            transform: translateX(-50%); 
            /* Ancho completo con maximo */
            width: 100%; 
            max-width: 430px; 
            /* Altura */
            height: 60px; 
            /* Fondo */
            background: var(--card); 
            /* Linea inferior */
            border-bottom: 1px solid var(--borde); 
            /* Flexbox */
            display: flex; 
            align-items: center; 
            justify-content: space-between; 
            /* Espaciado interno */
            padding: 0 16px; 
            /* Z-index alto para estar encima */
            z-index: 1000; 
        }
        
        /* Boton de menu hamburguesa (3 lineas) */
        #usa-app .btn-menu { 
            width: 40px; 
            height: 40px; 
            background: none; 
            border: none; 
            cursor: pointer; 
            display: flex; 
            flex-direction: column; 
            justify-content: center; 
            align-items: flex-start; 
            gap: 5px; 
        }
        /* Lineas del menu */
        #usa-app .btn-menu span { 
            width: 22px; 
            height: 2px; 
            background: var(--texto); 
            border-radius: 2px; 
            transition: 0.3s;
        }
        
        /* Contenedor del logo centrado */
        #usa-app .contenedor-logo { 
            position: absolute; 
            left: 50%; 
            top: 50%; 
            transform: translate(-50%, -50%); 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            height: 100%; 
            cursor: pointer;
        }
        
        /* Contenedor de iconos a la derecha */
        #usa-app .iconos-derecha { 
            display: flex; 
            gap: 4px; 
            align-items: center;
        }
        
        /* Boton de icono individual */
        #usa-app .btn-icono { 
            width: 36px; 
            height: 36px; 
            background: none; 
            border: none; 
            cursor: pointer; 
            position: relative; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            color: var(--texto); 
        }
        
        /* Globo contador amarillo (numero de items) */
        #usa-app .globo-contador { 
            position: absolute; 
            top: -2px; 
            right: -2px; 
            background: var(--oro); 
            color: #000; 
            font-size: 10px; 
            font-weight: bold; 
            width: 18px; 
            height: 18px; 
            border-radius: 50%; 
            display: flex; 
            align-items: center; 
            justify-content: center;
        }

        /* Contenedor principal del contenido */
        #usa-app .contenedor-principal { 
            /* Margen superior para no tapar con la barra + buscador */
            margin-top: 120px; 
            padding: 16px; 
            min-height: 80vh; 
        }

        /* ==================================================================
           [ 🔍 BUSCADOR EN HEADER (CABECERA) ]
           ==================================================================
           Buscador fijo debajo de la barra superior
           - Campo de texto redondeado
           - Boton circular dorado con lupa a la derecha
           - Autocompletar en tiempo real
           ================================================================== */
        
        /* Contenedor del buscador en header */
        #usa-app .header-buscador-contenedor {
            position: fixed;
            top: 60px;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            max-width: 430px;
            padding: 10px 16px;
            background: var(--card);
            border-bottom: 1px solid var(--borde);
            z-index: 999;
        }
        
        /* Caja del buscador */
        #usa-app .header-buscador-caja {
            display: flex;
            align-items: center;
            background: var(--fondo);
            border: 1px solid var(--borde);
            border-radius: 25px;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        
        /* Focus en el buscador */
        #usa-app .header-buscador-caja:focus-within {
            border-color: var(--oro);
            box-shadow: 0 0 15px rgba(255, 215, 0, 0.2);
        }
        
        /* Input del buscador */
        #usa-app .header-buscador-input {
            flex: 1;
            padding: 12px 16px;
            background: transparent;
            border: none;
            color: var(--texto);
            font-size: 14px;
            outline: none;
        }
        
        #usa-app .header-buscador-input::placeholder {
            color: var(--texto-secundario);
            opacity: 0.6;
        }
        
        /* Boton de buscar */
        #usa-app .header-buscador-boton {
            width: 36px;
            height: 36px;
            margin: 3px;
            background: var(--oro);
            border: none;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s ease;
            flex-shrink: 0;
        }
        
        #usa-app .header-buscador-boton:hover {
            transform: scale(1.05);
            filter: brightness(1.1);
        }
        
        #usa-app .header-buscador-boton svg {
            width: 16px;
            height: 16px;
            stroke: #000;
        }
        
        /* Contenedor de resultados de autocompletar */
        #usa-app .header-buscador-resultados {
            position: absolute;
            top: 100%;
            left: 16px;
            right: 16px;
            background: var(--card);
            border: 1px solid var(--borde);
            border-top: none;
            border-radius: 0 0 12px 12px;
            max-height: 350px;
            overflow-y: auto;
            z-index: 998;
            display: none;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }
        
        #usa-app .header-buscador-resultados.activo {
            display: block;
        }
        
        /* Item de resultado */
        #usa-app .header-resultado-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            cursor: pointer;
            transition: all 0.2s ease;
            border-bottom: 1px solid var(--borde);
        }
        
        #usa-app .header-resultado-item:last-child {
            border-bottom: none;
        }
        
        #usa-app .header-resultado-item:hover {
            background: rgba(255, 215, 0, 0.1);
        }
        
        #usa-app .header-resultado-img {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 8px;
            background: var(--fondo);
        }
        
        #usa-app .header-resultado-info {
            flex: 1;
            min-width: 0;
        }
        
        #usa-app .header-resultado-nombre {
            font-size: 13px;
            font-weight: 600;
            color: var(--texto);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        
        #usa-app .header-resultado-precio {
            font-size: 12px;
            color: var(--oro);
            font-weight: bold;
            margin-top: 2px;
        }
        
        #usa-app .header-resultado-vacio {
            padding: 15px;
            text-align: center;
            color: var(--texto-secundario);
            font-size: 13px;
        }
        
        #usa-app .header-resultado-ver-todos {
            padding: 12px;
            text-align: center;
            background: rgba(255, 215, 0, 0.1);
            color: var(--oro);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        
        #usa-app .header-resultado-ver-todos:hover {
            background: rgba(255, 215, 0, 0.2);
        }

        /* ====================================================================== 
           [ 🖼️ HERO Y CARRUSEL PRINCIPAL ]
           ==================================================================
           CARRUSEL DE IMAGENES EN LA PAGINA DE INICIO
           Muestra banners promocionales que cambian automaticamente
           ------------------------------------------------------------------
           - carrusel-hero: Contenedor del carrusel
           - slide-hero: Cada diapositiva individual
           - contenido-hero: Caja de texto sobre la imagen
           - etiqueta-hero: Label amarillo (ej: "SOMOS MAYORISTAS")
           - puntos-hero: Indicadores de puntos abajo
           - punto: Cada punto individual (activo = dorado)
           ================================================================== */
        
        /* Titulo de seccion con barra dorada */
        #usa-app .titulo-seccion { 
            font-size: 18px; 
            margin-bottom: 16px; 
            display: flex; 
            align-items: center; 
            gap: 10px; 
            scroll-margin-top: 80px; 
            font-weight: 700; 
        }
        /* Barra dorada antes del titulo */
        #usa-app .titulo-seccion::before { 
            content: ''; 
            width: 4px; 
            height: 20px; 
            background: var(--oro); 
            border-radius: 2px; 
        }
        
        /* Contenedor del carrusel principal */
        #usa-app .carrusel-hero { 
            position: relative; 
            height: 220px; 
            background: var(--card); 
            border-radius: 12px; 
            overflow: hidden; 
            margin-bottom: 20px; 
            border: 1px solid var(--borde); 
        }
        
        /* Cada slide/diapositiva del carrusel */
        #usa-app .slide-hero { 
            position: absolute; 
            inset: 0; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            opacity: 0; 
            transition: opacity 0.5s ease; 
            padding: 20px; 
            background-size: cover; 
            background-position: center; 
            z-index: 1;
        }
        /* Slide activo (visible) */
        #usa-app .slide-hero.activo { 
            opacity: 1; 
            z-index: 2; 
        }
        
        /* Caja de contenido sobre la imagen */
        #usa-app .contenido-hero { 
            text-align: center; 
            background: rgba(0,0,0,0.6); 
            padding: 15px; 
            border-radius: 12px; 
            width: 100%; 
            backdrop-filter: blur(2px); 
            border: 1px solid rgba(255,215,0,0.2); 
        }
        /* Titulo del slide */
        #usa-app .contenido-hero h2 { 
            color: var(--oro); 
            font-size: 20px; 
            margin-bottom: 4px; 
            text-shadow: 0 0 10px rgba(0,0,0,0.8); 
        }
        /* Descripcion del slide */
        #usa-app .contenido-hero p { 
            color: #fff; 
            font-size: 13px; 
            text-shadow: 0 0 5px rgba(0,0,0,0.8); 
        }
        
        /* Etiqueta amarilla (ej: "SOMOS MAYORISTAS") */
        #usa-app .etiqueta-hero { 
            background: var(--oro); 
            color: #000; 
            padding: 4px 10px; 
            border-radius: 6px; 
            font-size: 11px; 
            font-weight: bold; 
            display: inline-block; 
            margin-bottom: 8px; 
            text-transform: uppercase; 
        }
        
        /* Contenedor de puntos indicadores */
        #usa-app .puntos-hero { 
            position: absolute; 
            bottom: 10px; 
            left: 50%; 
            transform: translateX(-50%); 
            display: flex; 
            gap: 8px; 
            z-index: 10; 
        }
        /* Cada punto indicador */
        #usa-app .punto { 
            width: 8px; 
            height: 8px; 
            border-radius: 50%; 
            background: rgba(255,255,255,0.4); 
            border: none; 
            cursor: pointer; 
            transition: all 0.3s; 
        }
        /* Punto activo (slide actual) */
        #usa-app .punto.activo { 
            background: var(--oro); 
            transform: scale(1.3); 
        }

        /* Scroll horizontal para productos destacados */
        #usa-app .scroll-horizontal { 
            display: flex; 
            gap: 12px; 
            overflow-x: auto; 
            scroll-snap-type: x mandatory; 
            padding-bottom: 8px; 
            scrollbar-width: none; 
            margin-bottom: 20px; 
            scroll-behavior: smooth;
        }
        /* Ocultar barra de scroll */
        #usa-app .scroll-horizontal::-webkit-scrollbar { 
            display: none; 
        }

        /* ====================================================================== 
           [ 📦 CATEGORÍAS Y PRODUCTOS ]
           ==================================================================
           ESTILOS PARA LAS TARJETAS DE PRODUCTOS EN LA TIENDA
           ------------------------------------------------------------------
           - grilla-productos: Grid de 2 columnas para productos normales
           - tarjeta-producto: Caja individual de cada producto
           - btn-favorito: Boton de corazon para agregar a deseos
           - etiqueta-oferta: Label amarillo que dice "OFERTA"
           - img-producto: Imagen principal del producto
           - nombre-producto: Titulo del producto (maximo 2 lineas)
           - precio-actual: Precio en color dorado
           - precio-antiguo: Precio tachado (antes de descuento)
           - btn-principal: Boton amarillo de "Comprar Sabores"
           ================================================================== */
        
        /* Grilla de productos - 2 columnas en pantalla */
        #usa-app .grilla-productos { 
            display: grid; 
            /* 2 columnas de igual ancho */
            grid-template-columns: repeat(2, 1fr); 
            /* Espacio entre tarjetas */
            gap: 12px; 
        }
        
        /* Tarjeta individual de producto */
        #usa-app .tarjeta-producto { 
            /* Fondo usando variable de color */
            background: var(--card); 
            /* Esquinas redondeadas */
            border-radius: 12px; 
            /* Oculta contenido que se sale */
            overflow: hidden; 
            /* Borde delgado gris */
            border: 1px solid var(--borde); 
            /* Posicion relativa para elementos absolutos dentro */
            position: relative; 
            /* Flexbox en columna */
            display:flex; 
            flex-direction:column; 
            /* Cursor de mano al pasar */
            cursor:pointer;
        }
        
        /* Boton de favorito (corazon) en esquina superior derecha */
        #usa-app .btn-favorito { 
            position: absolute; 
            top: 6px; 
            right: 6px; 
            width: 30px; 
            height: 30px; 
            border-radius: 50%; 
            background: rgba(0,0,0,0.6); 
            border: none; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            cursor: pointer; 
            z-index: 5; 
            transition: all 0.3s;
        }
        /* Estado activo del boton favorito */
        #usa-app .btn-favorito.activo { background: var(--oro); }
        #usa-app .btn-favorito.activo img { filter: brightness(0); }
        /* Cambiar color del SVG cuando esta activo */
        #usa-app .btn-favorito.activo svg { stroke: #000; fill: var(--oro); }
        
        /* Etiqueta amarilla de OFERTA */
        #usa-app .etiqueta-oferta { 
            position: absolute; 
            top: 8px; 
            left: 8px; 
            background: var(--oro); 
            color: #000; 
            font-size: 10px; 
            font-weight: bold; 
            padding: 3px 8px; 
            border-radius: 4px; 
            z-index: 2; 
            pointer-events:none;
        }

        /* Imagen del producto */
        #usa-app .img-producto { 
            width: 100%; 
            /* Altura fija de la imagen */
            height: 130px; 
            object-fit: cover; 
            pointer-events: none;
        }
        
        /* Contenedor de informacion del producto */
        #usa-app .info-producto { 
            padding: 10px; 
            display:flex; 
            flex-direction:column; 
            flex:1; 
            pointer-events: none;
        }
        
        /* Nombre del producto (titulo) */
        #usa-app .nombre-producto { 
            font-size: 12px; 
            margin: 4px 0; 
            line-height: 1.3; 
            /* Limita a 2 lineas de texto */
            display: -webkit-box; 
            -webkit-line-clamp: 2; 
            -webkit-box-orient: vertical; 
            overflow: hidden; 
            min-height: 32px; 
            font-weight:bold;
        }
        
        /* Caja que contiene los precios */
        #usa-app .caja-precio-producto { 
            display: flex; 
            align-items: center; 
            gap: 6px; 
            margin-top: auto; 
            padding-top:6px; 
            flex-wrap: wrap;
        }
        
        /* Precio actual en color dorado */
        #usa-app .precio-actual { 
            font-size: 14px; 
            color: var(--oro); 
            font-weight: bold; 
        }
        
        /* Precio anterior tachado */
        #usa-app .precio-antiguo { 
            font-size: 11px; 
            color: var(--texto-secundario); 
            text-decoration: line-through; 
        }

        /* ==================================================================
           [ 📋 VISTA DE LISTA DE PRODUCTOS (UNA COLUMNA) ]
           ==================================================================
           Estilo similar a la foto: imagen a la izquierda, info a la derecha
           ================================================================== */
        
        /* Contenedor de filtros y ordenar */
        #usa-app .catalogo-filtros {
            display: flex;
            gap: 10px;
            margin-bottom: 16px;
            padding: 0 4px;
        }
        
        #usa-app .btn-filtro, #usa-app .btn-ordenar {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 16px;
            background: var(--card);
            border: 1px solid var(--borde);
            border-radius: 10px;
            color: var(--texto);
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        
        #usa-app .btn-filtro:hover, #usa-app .btn-ordenar:hover {
            border-color: var(--oro);
            background: rgba(255, 215, 0, 0.05);
        }
        
        #usa-app .btn-filtro svg, #usa-app .btn-ordenar svg {
            width: 18px;
            height: 18px;
            stroke: var(--texto-secundario);
        }
        
        /* Lista de productos en una columna */
        #usa-app .lista-productos {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        
        /* Tarjeta de producto en vista lista */
        #usa-app .producto-lista {
            display: flex;
            gap: 14px;
            background: var(--card);
            border: 1px solid var(--borde);
            border-radius: 12px;
            padding: 12px;
            position: relative;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        
        #usa-app .producto-lista:hover {
            border-color: var(--oro);
            box-shadow: 0 4px 15px rgba(255, 215, 0, 0.1);
        }
        
        /* Contenedor de imagen */
        #usa-app .producto-lista-img-contenedor {
            position: relative;
            width: 100px;
            height: 100px;
            flex-shrink: 0;
        }
        
        #usa-app .producto-lista-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            border-radius: 8px;
            background: var(--fondo);
        }
        
        /* Etiqueta de descuento */
        #usa-app .producto-lista-descuento {
            position: absolute;
            top: -4px;
            left: -4px;
            background: var(--error);
            color: #fff;
            font-size: 10px;
            font-weight: bold;
            padding: 4px 8px;
            border-radius: 6px;
        }
        
        /* Informacion del producto */
        #usa-app .producto-lista-info {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            min-width: 0;
        }
        
        /* Marca del producto */
        #usa-app .producto-lista-marca {
            font-size: 11px;
            color: var(--texto-secundario);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 2px;
        }
        
        /* Nombre del producto */
        #usa-app .producto-lista-nombre {
            font-size: 14px;
            font-weight: 600;
            color: var(--texto);
            line-height: 1.3;
            margin-bottom: 6px;
        }
        
        /* Estrellas de rating */
        #usa-app .producto-lista-rating {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 8px;
        }
        
        #usa-app .producto-lista-estrellas {
            color: var(--oro);
            font-size: 13px;
        }
        
        #usa-app .producto-lista-reviews {
            font-size: 11px;
            color: var(--texto-secundario);
        }
        
        /* Precios */
        #usa-app .producto-lista-precios {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 10px;
        }
        
        #usa-app .producto-lista-precio {
            font-size: 18px;
            font-weight: bold;
            color: var(--oro);
        }
        
        #usa-app .producto-lista-precio-antiguo {
            font-size: 13px;
            color: var(--texto-secundario);
            text-decoration: line-through;
        }
        
        /* Boton elegir opciones */
        #usa-app .producto-lista-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 10px 20px;
            background: transparent;
            border: 1px solid var(--oro);
            border-radius: 20px;
            color: var(--oro);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        /* ==================================================================
           [ 📋 RESUMEN DESTINATARIO EN METODO DE ENTREGA ]
           ================================================================== */
        #usa-app .resumen-destinatario {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--borde);
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 20px;
        }
        
        #usa-app .resumen-destinatario-titulo {
            font-size: 11px;
            color: var(--texto-secundario);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }
        
        #usa-app .resumen-destinatario-dato {
            font-size: 13px;
            color: var(--texto);
            margin-bottom: 4px;
            line-height: 1.4;
        }
        
        #usa-app .resumen-destinatario-dato strong {
            color: var(--oro);
            font-weight: 600;
        }
        
        /* Estilo para opciones de entrega mejorado */
        #usa-app .opcion-entrega {
            display: flex;
            align-items: center;
            gap: 15px;
            background: var(--fondo);
            border: 2px solid var(--borde);
            border-radius: 14px;
            padding: 18px 16px;
            margin-bottom: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        #usa-app .opcion-entrega:hover {
            border-color: rgba(255, 215, 0, 0.5);
            transform: translateY(-2px);
        }
        
        #usa-app .opcion-entrega.activo {
            border-color: var(--oro);
            background: rgba(255, 215, 0, 0.05);
            box-shadow: 0 0 20px rgba(255, 215, 0, 0.15);
        }
        
        #usa-app .radio-entrega {
            width: 24px;
            height: 24px;
            border: 2px solid var(--borde);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }
        
        #usa-app .opcion-entrega.activo .radio-entrega {
            border-color: var(--oro);
            background: var(--oro);
        }
        
        #usa-app .opcion-entrega.activo .radio-entrega::after {
            content: '';
            width: 10px;
            height: 10px;
            background: #000;
            border-radius: 50%;
        }
        
        #usa-app .del-icon {
            width: 44px;
            height: 44px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        
        #usa-app .opcion-entrega.activo .del-icon {
            background: var(--oro);
        }
        
        #usa-app .opcion-entrega.activo .del-icon img {
            filter: brightness(0);
        }
        
        #usa-app .info-entrega h4 {
            font-size: 15px;
            margin-bottom: 4px;
            color: var(--texto);
        }
        
        #usa-app .info-entrega p {
            font-size: 13px;
            color: var(--texto-secundario);
        }
            width: fit-content;
        }
        
        #usa-app .producto-lista-btn:hover {
            background: var(--oro);
            color: #000;
        }
        
        /* Boton favorito en lista */
        #usa-app .producto-lista .btn-favorito {
            position: absolute;
            top: 8px;
            right: 8px;
            width: 32px;
            height: 32px;
        }

        /* Boton principal amarillo de compra */
        #usa-app .btn-principal { 
            width: 100%; 
            margin-top: 10px; 
            padding: 10px; 
            background: var(--oro); 
            color: #000; 
            border: none; 
            border-radius: 20px; 
            font-size: 12px; 
            font-weight: 600; 
            cursor: pointer; 
            display:flex; 
            align-items:center; 
            justify-content:center; 
            gap:8px; 
            transition:0.2s; 
            pointer-events: auto;
        }
        /* Boton deshabilitado */
        #usa-app .btn-principal:disabled { 
            background: var(--borde); 
            color: var(--texto-secundario); 
            cursor: not-allowed; 
        }

        /* ====================================================================== 
           [ ⭐ RESEÑAS DE CLIENTES ]
           ==================================================================
           TARJETAS DE OPINIONES DE CLIENTES
           ------------------------------------------------------------------
           - tarjeta-resena: Caja con la opinion completa
           - avatar-resena: Circulo con la inicial del nombre
           - nombre-resena: Nombre del cliente
           - estrellas-resena: Estrellas doradas de calificacion
           - texto-resena: Texto de la opinion
           ================================================================== */
        
        /* Tarjeta individual de reseña */
        #usa-app .tarjeta-resena { 
            /* No se encoge, ancho fijo de 260px */
            flex: 0 0 260px; 
            scroll-snap-align: start; 
            background: var(--card); 
            border: 1px solid var(--borde); 
            border-radius: 12px; 
            padding: 14px; 
            display:flex; 
            flex-direction:column; 
            justify-content:center;
        }
        
        /* Cabecera con avatar y nombre */
        #usa-app .cabecera-resena { 
            display: flex; 
            align-items: center; 
            gap: 10px; 
            margin-bottom: 8px; 
        }
        
        /* Avatar circular con inicial */
        #usa-app .avatar-resena { 
            width: 32px; 
            height: 32px; 
            /* Degradado dorado */
            background: linear-gradient(135deg, var(--oro), #d4af37); 
            color: #000; 
            border-radius: 50%; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-weight: bold; 
            font-size: 14px; 
        }
        
        /* Nombre del cliente */
        #usa-app .nombre-resena { 
            font-size: 13px; 
            font-weight: bold; 
        }
        
        /* Estrellas de calificacion */
        #usa-app .estrellas-resena { 
            color: var(--oro); 
            font-size: 12px; 
            margin-bottom: 6px; 
        }
        
        /* Texto de la opinion */
        #usa-app .texto-resena { 
            font-size: 12px; 
            color: var(--texto-secundario); 
            line-height: 1.4; 
            font-style: italic; 
        }

        /* ====================================================================== 
           [ 🔍 MODAL POPUP DE PRODUCTO ]
           ====================================================================== */
        #usa-app .fondo-modal { position: fixed; inset: 0; background: rgba(0,0,0,0.8); display: flex; align-items: flex-end; justify-content: center; z-index: 2000; opacity: 0; visibility: hidden; transition: all 0.3s; }
        #usa-app .fondo-modal.activo { opacity: 1; visibility: visible; }
        #usa-app .caja-modal { width: 100%; max-width: 430px; background: var(--card); border-radius: 20px 20px 0 0; padding: 20px; max-height: 85vh; overflow-y: auto; transform: translateY(100%); transition: transform 0.3s; }
        #usa-app .fondo-modal.activo .caja-modal { transform: translateY(0); }
        #usa-app .cabecera-modal { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
        #usa-app .titulo-modal { font-size: 18px; font-weight:bold;}
        #usa-app .btn-cerrar-modal { width: 36px; height: 36px; background: rgba(255,255,255,0.1); border-radius: 50%; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--texto);}

        #usa-app .img-modal-principal { width: 100%; height: 200px; object-fit: contain; background: var(--fondo); border-radius: 10px; margin-bottom: 10px; }
        #usa-app .caja-miniaturas { display: flex; gap: 8px; margin-bottom: 16px; overflow-x: auto; padding-bottom: 5px; scrollbar-width: none;}
        #usa-app .img-miniatura { width: 55px; height: 55px; object-fit: cover; border-radius: 8px; border: 2px solid transparent; cursor: pointer; background: var(--fondo);}
        #usa-app .img-miniatura.activo { border-color: var(--oro); }

        #usa-app .desc-larga-modal { font-size: 12px; color: var(--texto-secundario); line-height: 1.5; margin-bottom: 15px; padding-bottom: 15px; border-bottom: 1px solid var(--borde);}
        #usa-app .grilla-sabores { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
        #usa-app .btn-sabor { padding: 8px 14px; background: var(--fondo); border: 1px solid var(--borde); border-radius: 20px; color: var(--texto); font-size: 12px; cursor: pointer; display:flex; align-items:center; gap:4px; transition: all 0.2s;}
        #usa-app .btn-sabor.activo { background: var(--oro); border-color: var(--oro); color: #000; font-weight: 600; }

        #usa-app .caja-cantidad { display: flex; align-items: center; justify-content: center; gap: 16px; margin-bottom: 20px;}
        #usa-app .btn-cant { width: 40px; height: 40px; background: var(--fondo); border: 1px solid var(--borde); border-radius: 50%; color: var(--texto); font-size: 18px; cursor: pointer; transition: 0.2s;}

        /* ====================================================================== 
           [ 🛒 CARRITO Y RESUMEN ]
           ====================================================================== */
        #usa-app .item-carrito { display: flex; gap: 12px; background: var(--card); border-radius: 12px; padding: 12px; margin-bottom: 12px; border: 1px solid var(--borde); }
        #usa-app .img-item-carrito { width: 70px; height: 70px; object-fit: cover; border-radius: 8px; background: var(--fondo);}
        #usa-app .info-item-carrito { flex: 1; display:flex; flex-direction:column;}
        #usa-app .nombre-item-carrito { font-size: 13px; margin-bottom: 4px; font-weight:600;}
        #usa-app .sabor-item-carrito { font-size: 11px; color: var(--texto-secundario); margin-bottom: 6px; line-height: 1.3;}
        #usa-app .precio-item-carrito { font-size: 14px; color: var(--oro); font-weight: bold; margin-top:auto;}
        #usa-app .acciones-item-carrito { display: flex; align-items: center; gap: 8px; margin-top: 8px; background:var(--fondo); padding:4px 8px; border-radius:20px; width:fit-content;}
        #usa-app .btn-eliminar-carrito { width: 26px; height: 26px; background: transparent; border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--texto); font-size:16px;}
        #usa-app .btn-eliminar-carrito.basurero { color: var(--error); margin-left:auto;}

        #usa-app .caja-resumen-compra { background: var(--card-light); border-radius: 12px; padding: 16px; border: 1px solid var(--borde); margin-bottom: 20px; }
        #usa-app .caja-resumen-compra .titulo { font-size: 14px; font-weight: 600; margin-bottom: 12px; display:flex; align-items:center; gap:8px;}
        #usa-app .fila-resumen { display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 14px; color: var(--texto-secundario);}
        #usa-app .fila-resumen.total { border-top: 1px dashed var(--borde); padding-top: 12px; margin-top: 5px; font-size: 16px; font-weight: bold; color: var(--texto);}
        #usa-app .fila-resumen.total .valor { color: var(--oro); font-size: 18px;}

        /* ====================================================================== 
           [ 📝 FORMULARIOS (Checkout, Login, Registro) ]
           ====================================================================== */
        @keyframes vibrarCaja { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }
        #usa-app .grupo-form { margin-bottom: 14px; position:relative;}
        #usa-app .fila-form { display: flex; gap: 10px; }
        #usa-app .fila-form .grupo-form { flex: 1; }
        #usa-app .etiqueta-form { display: block; font-size: 12px; color: var(--texto-secundario); margin-bottom: 6px; }
        #usa-app .envoltura-input { position: relative; display: flex; align-items: center; }
        #usa-app .input-form { width: 100%; padding: 12px 14px; padding-right:35px; background: var(--fondo); border: 1px solid var(--borde); border-radius: 8px; color: var(--texto); font-size: 14px; outline:none; transition: border-color 0.3s;}
        #usa-app .input-form:focus { border-color: var(--oro); }

        #usa-app select.input-form { background-color: var(--fondo) !important; color: var(--texto) !important; }
        #usa-app select.input-form option { background-color: var(--card) !important; color: var(--texto) !important; }

        #usa-app .grupo-form.con-error .input-form { border-color: var(--error); background: rgba(255,68,68,0.05); animation: vibrarCaja 0.3s ease-in-out; }
        #usa-app .grupo-form.con-exito .input-form { border-color: var(--exito); background: rgba(0,200,81,0.02); }
        #usa-app .icono-estado { position: absolute; right: 12px; font-size: 14px; font-weight:bold; display:none; }
        #usa-app .grupo-form.con-exito .icono-estado { display:block; color: var(--exito); }
        #usa-app .grupo-form.con-error .icono-estado { display:block; color: var(--error); }
        #usa-app .msj-error { font-size: 11px; color: var(--error); margin-top: 4px; display: none; }
        #usa-app .grupo-form.con-error .msj-error { display: block; }

        /* Línea de progreso (Stepper) en Checkout */
        #usa-app .barra-progreso { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; position: relative; padding: 0 10px; }
        #usa-app .barra-progreso::before { content: ''; position: absolute; top: 12px; left: 30px; right: 30px; height: 2px; background: var(--borde); z-index: 1; }
        #usa-app .paso { display: flex; flex-direction: column; align-items: center; gap: 6px; position: relative; z-index: 2; width: 33%;}
        #usa-app .circulo-paso { width: 26px; height: 26px; border-radius: 50%; background: var(--card); border: 2px solid var(--borde); color: var(--texto-secundario); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold; transition: all 0.3s;}
        #usa-app .texto-paso { font-size: 10px; color: var(--texto-secundario); text-transform: uppercase; font-weight: 600; text-align: center; }
        #usa-app .paso.activo .circulo-paso { border-color: var(--oro); background: rgba(255,215,0,0.1); color: var(--oro); }
        #usa-app .paso.activo .texto-paso { color: var(--oro); }
        #usa-app .paso.completado .circulo-paso { background: var(--oro); border-color: var(--oro); color: #000; }
        #usa-app .paso.completado .texto-paso { color: var(--texto); }

        /* ====================================================================== 
           [ 🔍 BUSCADOR DE PRODUCTOS ]
           ==================================================================
           Buscador estilo similar al de la imagen
           - Campo de texto redondeado
           - Boton circular dorado con lupa a la derecha
           ================================================================== */

        /* ====================================================================== 
           [ 🚚 OPCIONES DE ENTREGA ]
           ====================================================================== */
        #usa-app .opcion-entrega { display: flex; align-items: flex-start; gap: 12px; background: var(--fondo); border: 2px solid var(--borde); border-radius: 12px; padding: 16px; margin-bottom: 12px; cursor: pointer; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); position:relative; overflow:hidden;}
        #usa-app .opcion-entrega:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(255, 215, 0, 0.1); border-color: rgba(255,215,0,0.5);}
        #usa-app .opcion-entrega.activo { border-color: var(--oro); background: rgba(255,215,0,0.05); transform: scale(1.02); box-shadow: 0 0 15px rgba(255,215,0,0.15); }
        #usa-app .radio-entrega { width: 22px; height: 22px; border: 2px solid var(--borde); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; transition: all 0.3s;}
        #usa-app .opcion-entrega.activo .radio-entrega { border-color: var(--oro); }
        #usa-app .opcion-entrega.activo .radio-entrega::after { content: ''; width: 10px; height: 10px; background: var(--oro); border-radius: 50%; box-shadow: 0 0 8px var(--oro);}
        #usa-app .info-entrega { flex: 1; }
        #usa-app .info-entrega h4 { font-size: 14px; margin-bottom: 4px; color: var(--texto);}
        #usa-app .info-entrega p { font-size: 12px; color: var(--texto-secundario); line-height: 1.4;}

        /* ====================================================================== 
           [ 🏢 ESTILOS POPUP SUCURSALES (SWEETALERT GLOBAL) ]
           ====================================================================== */
        .swal2-container { z-index: 5000 !important; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
        .swal2-popup { background: #141414 !important; color: #ffffff !important; border: 1px solid #2a2a2a; border-radius: 16px !important; width: 90% !important; max-width: 430px !important;}
        .swal2-title { color: #FFD700 !important; font-size: 1.3em !important; padding-top: 15px !important;}
        .swal2-close { color: #b0b0b0 !important; }
        .swal2-close:hover { color: #FFD700 !important; }
        .swal2-html-container { color: #ffffff !important; margin: 0 !important; padding: 0 1em 1em 1em !important; }

        /* Diseño de Tarjeta en Columna para sucursales (Imagen arriba, Texto abajo) */
        .contenedor-sucursales { display: flex; flex-direction: column; gap: 15px; margin-top: 15px; }
        .tarjeta-sucursal { border: 1px solid #2a2a2a; border-radius: 12px; padding: 16px; cursor: pointer; display: flex; flex-direction: column; align-items: center; text-align: center; transition: all 0.2s ease; background: #0a0a0a; }
        .tarjeta-sucursal:hover { border-color: #FFD700; box-shadow: 0 4px 12px rgba(255,215,0,0.1); }
        .tarjeta-sucursal img.img-suc { object-fit: cover; border-radius: 8px; margin: 0 auto 12px auto; display: block;}

        .info-sucursal { width: 100%; }
        .info-sucursal h4 { margin: 0 0 8px 0; font-size: 16px; color: #ffffff; font-weight: bold; }
        .info-sucursal p { margin: 6px 0; font-size: 13px; color: #b0b0b0; display: flex; align-items: center; justify-content: center; gap: 6px; line-height: 1.3;}
        .info-sucursal p img { width: 16px !important; height: 16px !important; flex-shrink: 0; display: inline-block; margin: 0; }
        .info-sucursal .stock-texto { color: #00C851; font-weight: 600; margin-top: 8px; }

        /* Botón Starken forzado en el popup de alerta */
        .btn-swal-starken { background-color: #FFD700 !important; color: #000000 !important; font-weight: bold !important; border-radius: 20px !important; padding: 12px 24px !important; border: none !important; font-size: 14px !important; cursor: pointer; transition: 0.2s; width: 100%; max-width: 250px;}
        .btn-swal-starken:hover { opacity: 0.9; transform: scale(1.02); }

        /* ====================================================================== 
           [ 🏦 TRANSFERENCIA BANCARIA (Upload y Temporizador) ]
           ====================================================================== */
        #usa-app .caja-transferencia { background: rgba(255,215,0,0.05); border: 1px dashed var(--oro); border-radius: 12px; padding: 20px; margin-bottom: 20px; text-align: center; }
        #usa-app .monto-transferencia { font-size: 28px; color: var(--oro); font-weight: bold; margin: 15px 0; }

        #usa-app .caja-temporizador { background: rgba(255,40,40,0.05); border: 1px solid rgba(255,68,68,0.3); border-radius: 8px; color: #fff; }

        #usa-app .upload-box { position: relative; border: 2px dashed var(--borde); border-radius: 12px; padding: 20px; text-align: center; cursor: pointer; transition: all 0.3s; background: var(--card); margin-top: 15px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px;}
        #usa-app .upload-box:hover { border-color: var(--oro); background: rgba(255,215,0,0.02); }
        #usa-app .upload-box input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;}


        #usa-app .upload-text { font-size: 13px; color: var(--texto-secundario); pointer-events: none;}
        #usa-app .upload-text span { color: var(--oro); font-weight: bold; }
        #usa-app .preview-img { max-width: 100%; max-height: 150px; border-radius: 8px; display: none; object-fit: contain; pointer-events: none; margin-top: 10px;}

        /* POPUP DE ÉXITO ELEGANTE AL ENVIAR COMPROBANTE */
        #usa-app .popup-exito { position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 4000; display: flex; align-items: center; justify-content: center; opacity: 0; visibility: hidden; transition: 0.3s; backdrop-filter: blur(5px); }
        #usa-app .popup-exito.activo { opacity: 1; visibility: visible; }
        #usa-app .caja-exito { background: var(--card); border: 1px solid var(--exito); border-radius: 16px; padding: 30px 20px; width: 90%; max-width: 350px; text-align: center; transform: scale(0.9); transition: 0.3s; box-shadow: 0 10px 30px rgba(0,200,81,0.15); }
        #usa-app .popup-exito.activo .caja-exito { transform: scale(1); }
        #usa-app .icono-exito { width: 60px; height: 60px; background: rgba(0,200,81,0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 15px; }

        /* ====================================================================== 
           [ 🧑‍💻 PÁGINA "MI CUENTA" Y CONTACTO ]
           ====================================================================== */
        #usa-app .tarjeta-contacto { background: var(--card); border: 1px solid var(--borde); border-radius: 12px; padding: 20px; margin-bottom: 20px; }
        #usa-app .item-contacto { display: flex; gap: 12px; margin-bottom: 16px; align-items: flex-start;}
        #usa-app .texto-contacto { font-size: 14px; color: var(--texto-secundario); line-height: 1.5; }
        #usa-app .tarjeta-auth { background: var(--card); border: 1px solid var(--borde); border-radius: 12px; padding: 24px; text-align: center;}

        #usa-app .pestanas-panel { display: flex; gap: 10px; margin-bottom: 15px; border-bottom: 1px solid var(--borde); overflow-x: auto; white-space: nowrap; scrollbar-width: none;}
        #usa-app .pestanas-panel::-webkit-scrollbar { display: none; }
        #usa-app .pestana { padding: 10px 15px; cursor: pointer; color: var(--texto-secundario); border-bottom: 2px solid transparent; font-size: 13px; font-weight: bold; flex-shrink: 0;}
        #usa-app .pestana.activo { color: var(--oro); border-color: var(--oro); }
        #usa-app .contenido-pestana { display: none; }
        #usa-app .contenido-pestana.activo { display: block; }
        #usa-app .tarjeta-pedido { background: var(--fondo); border: 1px solid var(--borde); border-radius: 8px; padding: 12px; margin-bottom: 12px;}
        #usa-app .cabecera-pedido { display: flex; justify-content: space-between; font-size: 12px; color: var(--texto-secundario); margin-bottom: 8px; border-bottom: 1px solid var(--borde); padding-bottom: 8px;}

        /* ====================================================================== 
           [ 🦶 FOOTER (Pie de página) Y MENÚ INFERIOR ]
           ====================================================================== */
        /* ==================================================================
           [ 👣 FOOTER / PIE DE PAGINA ]
           ================================================================== */
        #usa-app .pie-pagina { 
            background: var(--card); 
            border-top: 1px solid var(--borde); 
            padding: 25px 16px 100px; 
            margin-top: 30px; 
        }
        
        /* Seccion del footer */
        #usa-app .footer-seccion {
            margin-bottom: 20px;
        }
        
        /* Titulo de seccion */
        #usa-app .footer-titulo {
            font-size: 13px;
            font-weight: 700;
            color: var(--texto);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
        }
        
        /* Badges de seguridad */
        #usa-app .footer-badges {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        
        #usa-app .badge-item {
            display: flex;
            align-items: center;
            gap: 6px;
            background: var(--fondo);
            border: 1px solid var(--borde);
            border-radius: 8px;
            padding: 8px 12px;
        }
        
        #usa-app .badge-item svg {
            width: 20px;
            height: 20px;
        }
        
        #usa-app .badge-item span {
            font-size: 11px;
            color: var(--texto-secundario);
        }
        
        /* Medios de pago */
        #usa-app .footer-pagos {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }
        
        #usa-app .metodo-pago {
            background: var(--fondo);
            border: 1px solid var(--borde);
            border-radius: 6px;
            padding: 8px 14px;
            font-size: 11px;
            font-weight: 600;
            color: var(--texto-secundario);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        /* Separador */
        #usa-app .footer-separador {
            height: 1px;
            background: var(--borde);
            margin: 20px 0;
        }
        
        /* Redes sociales */
        #usa-app .footer-redes {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 15px;
        }
        
        /* Icono de red social circular */
        #usa-app .icono-red {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: var(--texto);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            cursor: pointer;
            text-decoration: none;
        }
        
        #usa-app .icono-red svg {
            width: 22px;
            height: 22px;
            color: var(--fondo);
        }
        
        #usa-app .icono-red:hover {
            transform: scale(1.1);
        }
        
        /* Colores especificos para cada red social */
        #usa-app .icono-red.social-instagram:hover { background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }
        #usa-app .icono-red.social-facebook:hover { background: #1877F2; }
        #usa-app .icono-red.social-pinterest:hover { background: #E60023; }
        #usa-app .icono-red.social-tiktok:hover { background: #000; border: 2px solid #fff; }
        #usa-app .icono-red.social-youtube:hover { background: #FF0000; }
        
        /* WhatsApp destacado */
        #usa-app .footer-whatsapp {
            margin-top: 15px;
        }
        
        #usa-app .btn-whatsapp-footer {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: #25D366;
            color: #fff;
            padding: 12px 24px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.3s ease;
        }
        
        #usa-app .btn-whatsapp-footer:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4);
        }
        
        #usa-app .btn-whatsapp-footer svg {
            width: 20px;
            height: 20px;
        }
        
        /* Copyright */
        #usa-app .footer-copy { 
            font-size: 11px; 
            color: var(--texto-secundario); 
            border-top: 1px solid var(--borde); 
            padding-top: 15px; 
            text-align: center;
            margin-top: 15px;
        }

        /* ==================================================================
           [ 🛡️ PAGINA DE AUTENTICIDAD ]
           ================================================================== */
        #usa-app #pagina-autenticidad {
            padding: 16px;
        }
        
        #usa-app .autenticidad-seccion {
            margin-bottom: 25px;
        }
        
        #usa-app .autenticidad-titulo-principal {
            font-size: 22px;
            font-weight: 700;
            color: var(--oro);
            margin-bottom: 15px;
            line-height: 1.3;
        }
        
        #usa-app .autenticidad-texto {
            font-size: 14px;
            color: var(--texto);
            line-height: 1.7;
            margin-bottom: 10px;
        }
        
        /* Contenedor de tarjetas */
        #usa-app .autenticidad-tarjetas {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin: 25px 0;
        }
        
        /* Tarjeta individual */
        #usa-app .autenticidad-card {
            background: var(--card);
            border: 1px solid var(--borde);
            border-radius: 16px;
            padding: 24px 20px;
            text-align: center;
            transition: all 0.3s ease;
        }
        
        #usa-app .autenticidad-card:hover {
            border-color: var(--oro);
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(255, 215, 0, 0.1);
        }
        
        /* Icono de la tarjeta */
        #usa-app .autenticidad-icono {
            width: 60px;
            height: 60px;
            margin: 0 auto 16px;
            background: linear-gradient(135deg, var(--oro), #d4af37);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        #usa-app .autenticidad-icono svg {
            width: 30px;
            height: 30px;
            color: #000;
        }
        
        /* Titulo de la tarjeta */
        #usa-app .autenticidad-card-titulo {
            font-size: 16px;
            font-weight: 700;
            color: var(--oro);
            margin-bottom: 12px;
        }
        
        /* Texto de la tarjeta */
        #usa-app .autenticidad-card-texto {
            font-size: 13px;
            color: var(--texto-secundario);
            line-height: 1.6;
        }
        
        /* Seccion final */
        #usa-app .autenticidad-seccion-final {
            background: var(--card);
            border: 1px solid var(--borde);
            border-radius: 16px;
            padding: 24px 20px;
            margin-top: 25px;
        }
        
        #usa-app .autenticidad-titulo-final {
            font-size: 20px;
            font-weight: 700;
            color: var(--texto);
            margin-bottom: 12px;
        }
        
        #usa-app .autenticidad-texto-final {
            font-size: 14px;
            color: var(--texto-secundario);
            line-height: 1.7;
        }

        /* ==================================================================
           [ 📧 FORMULARIO DE SUSCRIPCION ]
           ================================================================== */
        #usa-app .seccion-suscripcion {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            padding: 40px 20px;
            margin-top: 30px;
            border-top: 1px solid var(--borde);
            border-bottom: 1px solid var(--borde);
        }
        
        #usa-app .suscripcion-contenedor {
            max-width: 400px;
            margin: 0 auto;
            text-align: center;
        }
        
        #usa-app .suscripcion-icono {
            width: 60px;
            height: 60px;
            margin: 0 auto 15px;
            background: rgba(255, 215, 0, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        #usa-app .suscripcion-icono svg {
            width: 30px;
            height: 30px;
            color: var(--oro);
        }
        
        #usa-app .suscripcion-titulo {
            font-size: 28px;
            font-weight: 700;
            color: var(--texto);
            margin-bottom: 8px;
        }
        
        #usa-app .suscripcion-subtitulo {
            font-size: 14px;
            color: var(--texto-secundario);
            margin-bottom: 25px;
        }
        
        #usa-app .suscripcion-formulario {
            width: 100%;
        }
        
        #usa-app .suscripcion-campos {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        
        #usa-app .suscripcion-input {
            flex: 1;
            min-width: 200px;
            padding: 14px 18px;
            background: var(--card);
            border: 1px solid var(--borde);
            border-radius: 10px;
            color: var(--texto);
            font-size: 15px;
            outline: none;
            transition: all 0.3s ease;
        }
        
        #usa-app .suscripcion-input:focus {
            border-color: var(--oro);
            box-shadow: 0 0 15px rgba(255, 215, 0, 0.2);
        }
        
        #usa-app .suscripcion-input::placeholder {
            color: var(--texto-secundario);
            opacity: 0.6;
        }
        
        #usa-app .suscripcion-boton {
            padding: 14px 30px;
            background: var(--oro);
            color: #000;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            min-width: 100px;
        }
        
        #usa-app .suscripcion-boton:hover {
            transform: scale(1.05);
            filter: brightness(1.1);
            box-shadow: 0 4px 15px rgba(255, 215, 0, 0.4);
        }
        
        #usa-app .suscripcion-boton:disabled {
            background: var(--borde);
            color: var(--texto-secundario);
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }
        
        #usa-app .suscripcion-mensaje {
            display: block;
            margin-top: 12px;
            font-size: 13px;
            min-height: 20px;
        }
        
        #usa-app .suscripcion-mensaje.exito {
            color: var(--exito);
        }
        
        #usa-app .suscripcion-mensaje.error {
            color: var(--error);
        }

        /* ==================================================================
           [ 🏋️ CARRUSEL DE CREATINAS - AUTO-REPRODUCCION ]
           ================================================================== */
        #usa-app .carrusel-creatinas-contenedor {
            position: relative;
            overflow: hidden;
            padding: 10px 0;
        }
        
        #usa-app .carrusel-creatinas {
            display: flex;
            gap: 12px;
            overflow-x: auto;
            scroll-behavior: smooth;
            scrollbar-width: none;
            padding: 5px 4px 15px;
            scroll-snap-type: x mandatory;
        }
        
        #usa-app .carrusel-creatinas::-webkit-scrollbar {
            display: none;
        }
        
        /* Tarjeta de producto en carrusel de creatinas */
        #usa-app .creatina-card {
            flex: 0 0 160px;
            scroll-snap-align: start;
            background: var(--card);
            border: 1px solid var(--borde);
            border-radius: 12px;
            overflow: hidden;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
        }
        
        #usa-app .creatina-card:hover {
            border-color: var(--oro);
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(255, 215, 0, 0.15);
        }
        
        #usa-app .creatina-card .btn-favorito {
            position: absolute;
            top: 6px;
            right: 6px;
            width: 28px;
            height: 28px;
            z-index: 5;
        }
        
        #usa-app .creatina-img {
            width: 100%;
            height: 130px;
            object-fit: cover;
            background: var(--fondo);
        }
        
        #usa-app .creatina-info {
            padding: 10px;
        }
        
        #usa-app .creatina-nombre {
            font-size: 12px;
            font-weight: 600;
            color: var(--texto);
            line-height: 1.3;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            margin-bottom: 6px;
            min-height: 32px;
        }
        
        #usa-app .creatina-precio {
            font-size: 14px;
            color: var(--oro);
            font-weight: bold;
        }

        #usa-app .menu-inferior { position: fixed; bottom: 0; left: 50%; transform: translateX(-50%); width: 100%; max-width: 430px; height: 65px; background: var(--card); border-top: 1px solid var(--borde); display: flex; justify-content: space-around; align-items: center; z-index: 1000; }
        #usa-app .item-menu-inf { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 8px 16px; background: none; border: none; cursor: pointer; color: var(--texto-secundario); transition: color 0.2s;}
        #usa-app .item-menu-inf.activo { color: var(--oro); filter: brightness(1.2); }

        /* ====================================================================== 
           [ 🍔 SIDEBARS (Menú lateral izquierdo y Panel derecho de Favoritos) ]
           ====================================================================== */
        #usa-app .capa-lateral { position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 1500; opacity: 0; visibility: hidden; transition: all 0.3s; }
        #usa-app .capa-lateral.activo { opacity: 1; visibility: visible; }
        #usa-app .barra-lateral { position: fixed; top: 0; height: 100%; background: var(--card); z-index: 1600; transition: transform 0.3s; overflow-y: auto;}
        #usa-app .barra-izquierda { left: 0; width: 280px; transform: translateX(-100%); border-right: 1px solid var(--borde); }
        #usa-app .barra-derecha { right: 0; width: 320px; transform: translateX(100%); border-left: 1px solid var(--borde); }
        #usa-app .capa-lateral.activo .barra-lateral { transform: translateX(0); }
        #usa-app .menu-lateral a { display: flex; align-items: center; gap: 14px; padding: 14px 20px; color: var(--texto-secundario); text-decoration: none; font-size: 15px; border-left: 3px solid transparent; cursor: pointer;}
        #usa-app .menu-lateral a:hover { background: rgba(255,215,0,0.05); border-left-color: var(--oro); color: var(--oro); }

        /* ==================================================================
           [ 🔍 BUSCADOR EN MENU LATERAL CON AUTOCOMPLETAR ]
           ================================================================== */
        
        /* Contenedor del buscador en el menu */
        #usa-app .menu-buscador-contenedor {
            padding: 15px;
            border-bottom: 1px solid var(--borde);
            position: relative;
        }
        
        /* Caja del buscador */
        #usa-app .menu-buscador-caja {
            display: flex;
            align-items: center;
            background: var(--fondo);
            border: 1px solid var(--borde);
            border-radius: 25px;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        
        /* Focus en el buscador */
        #usa-app .menu-buscador-caja:focus-within {
            border-color: var(--oro);
            box-shadow: 0 0 10px rgba(255, 215, 0, 0.2);
        }
        
        /* Input del buscador */
        #usa-app .menu-buscador-input {
            flex: 1;
            padding: 12px 15px;
            background: transparent;
            border: none;
            color: var(--texto);
            font-size: 14px;
            outline: none;
        }
        
        #usa-app .menu-buscador-input::placeholder {
            color: var(--texto-secundario);
            opacity: 0.6;
        }
        
        /* Boton de buscar */
        #usa-app .menu-buscador-boton {
            width: 36px;
            height: 36px;
            margin: 3px;
            background: var(--oro);
            border: none;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s ease;
            flex-shrink: 0;
        }
        
        #usa-app .menu-buscador-boton:hover {
            transform: scale(1.05);
            filter: brightness(1.1);
        }
        
        #usa-app .menu-buscador-boton svg {
            width: 16px;
            height: 16px;
            stroke: #000;
        }
        
        /* Contenedor de resultados de autocompletar */
        #usa-app .menu-buscador-resultados {
            position: absolute;
            top: 100%;
            left: 15px;
            right: 15px;
            background: var(--card);
            border: 1px solid var(--borde);
            border-top: none;
            border-radius: 0 0 12px 12px;
            max-height: 300px;
            overflow-y: auto;
            z-index: 1700;
            display: none;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }
        
        /* Cuando hay resultados */
        #usa-app .menu-buscador-resultados.activo {
            display: block;
        }
        
        /* Item individual de resultado */
        #usa-app .resultado-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            cursor: pointer;
            transition: all 0.2s ease;
            border-bottom: 1px solid var(--borde);
        }
        
        #usa-app .resultado-item:last-child {
            border-bottom: none;
        }
        
        #usa-app .resultado-item:hover {
            background: rgba(255, 215, 0, 0.1);
        }
        
        /* Imagen del producto en resultado */
        #usa-app .resultado-img {
            width: 45px;
            height: 45px;
            object-fit: cover;
            border-radius: 8px;
            background: var(--fondo);
        }
        
        /* Info del producto en resultado */
        #usa-app .resultado-info {
            flex: 1;
            min-width: 0;
        }
        
        #usa-app .resultado-nombre {
            font-size: 13px;
            font-weight: 600;
            color: var(--texto);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        
        #usa-app .resultado-precio {
            font-size: 12px;
            color: var(--oro);
            font-weight: bold;
            margin-top: 2px;
        }
        
        /* Mensaje sin resultados */
        #usa-app .resultado-vacio {
            padding: 15px;
            text-align: center;
            color: var(--texto-secundario);
            font-size: 13px;
        }
        
        /* Ver todos los resultados */
        #usa-app .resultado-ver-todos {
            padding: 12px;
            text-align: center;
            background: rgba(255, 215, 0, 0.1);
            color: var(--oro);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        
        #usa-app .resultado-ver-todos:hover {
            background: rgba(255, 215, 0, 0.2);
        }

        /* ====================================================================== 
           [ 🔔 TOASTS (Notificaciones emergentes verdes/rojas) ]
           ====================================================================== */
        #usa-app .contenedor-toast { position: fixed; top: 70px; left: 50%; transform: translateX(-50%); z-index: 3000; display: flex; flex-direction: column; gap: 10px; width: 90%; max-width: 400px; pointer-events: none;}
        #usa-app .toast { padding: 14px; border-radius: 10px; display: flex; align-items: center; gap: 10px; animation: slideIn 0.3s, fadeOut 0.3s 2.7s; pointer-events: auto; font-size:14px; font-weight:500;}
        #usa-app .toast.exito { background: var(--exito); color: #fff; }
        #usa-app .toast.error { background: var(--error); color: #fff; }
        @keyframes slideIn { from { transform: translateY(-20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        @keyframes fadeOut { from { opacity: 1; } to { opacity: 0; } }
    

        /* ====================================================================== 
           [ 📦 SECCION CATEGORIAS - DISEÑO VERTICAL CUADRADO ]
           ====================================================================== 

           INSTRUCCIONES DE MODIFICACION:
           -------------------------------
           - Para cambiar el tamaño de las tarjetas: Modifica --cat-tamano
           - Para cambiar el espacio entre tarjetas: Modifica --cat-espacio
           - Para cambiar la velocidad de animaciones: Modifica --cat-velocidad
           - Para cambiar el radio de esquinas: Modifica --cat-radio

        */

        /* ==================================================================
           [ 🎨 VARIABLES DE CATEGORIAS - 100% EDITABLES ]
           ==================================================================
           INSTRUCCIONES PARA MODIFICAR:
           -------------------------------
           --cat-tamano: Cambia el tamaño de las tarjetas (ancho y alto)
           --cat-espacio: Espacio vertical entre cada tarjeta
           --cat-velocidad: Velocidad de las animaciones (segundos)
           --cat-radio: Cuanto redondeadas son las esquinas
           --cat-sombra: Tamaño de la sombra al hacer hover
           --cat-brillo: Color y transparencia del brillo dorado
        ================================================================== */
        #usa-app {
            /* TAMAÑO DE LAS TARJETAS CUADRADAS - AJUSTA ESTE VALOR */
            --cat-tamano: 300px;
            /* ESPACIO ENTRE TARJETAS */
            --cat-espacio: 25px;
            /* VELOCIDAD DE ANIMACIONES (0.3s = rapido, 0.8s = lento) */
            --cat-velocidad: 0.4s;
            /* REDONDEO DE ESQUINAS (0px = cuadrado perfecto, 50px = circular) */
            --cat-radio: 24px;
            /* TAMAÑO DE LA SOMBRA */
            --cat-sombra: 20px;
            /* COLOR DEL BRILLO DORADO (formato: rgba(rojo, verde, azul, transparencia)) */
            --cat-brillo: rgba(255, 215, 0, 0.5);
        }

        /* Contenedor principal de la seccion categorias */
        #usa-app .seccion-categorias {
            margin-bottom: 30px;
            padding: 0 10px;
        }

        /* Titulo de la seccion con animacion */
        #usa-app .titulo-categorias {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--texto);
            /* Animacion de entrada */
            animation: fadeInDown 0.6s ease-out;
        }

        /* Barra decorativa dorada al lado del titulo */
        #usa-app .titulo-categorias::before {
            content: '';
            width: 5px;
            height: 28px;
            background: linear-gradient(180deg, var(--oro), #FFA500);
            border-radius: 3px;
            box-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
        }

        /* Contenedor vertical de categorias - UNA EN UNA */
        #usa-app .lista-categorias-vertical {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: var(--cat-espacio);
            padding: 10px 0;
        }

        /* ====================================================================== 
           [ 🎯 TARJETA DE CATEGORIA CUADRADA CON ANIMACIONES ]
           ====================================================================== */
        #usa-app .categoria-card {
            position: relative;
            width: var(--cat-tamano);
            height: var(--cat-tamano);
            border-radius: var(--cat-radio);
            overflow: hidden;
            cursor: pointer;
            /* Sombra inicial suave */
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
            /* Transicion suave para todos los cambios */
            transition: all var(--cat-velocidad) cubic-bezier(0.4, 0, 0.2, 1);
            /* Animacion de entrada escalonada */
            opacity: 0;
            transform: translateY(30px) scale(0.9);
            animation: entradaCategoria 0.5s ease-out forwards;
            border: 2px solid transparent;
        }

        /* Animacion de entrada para cada tarjeta - se activa con JavaScript */
        @keyframes entradaCategoria {
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        /* Retrasos escalonados para la animacion de entrada */
        #usa-app .categoria-card:nth-child(1) { animation-delay: 0.1s; }
        #usa-app .categoria-card:nth-child(2) { animation-delay: 0.15s; }
        #usa-app .categoria-card:nth-child(3) { animation-delay: 0.2s; }
        #usa-app .categoria-card:nth-child(4) { animation-delay: 0.25s; }
        #usa-app .categoria-card:nth-child(5) { animation-delay: 0.3s; }
        #usa-app .categoria-card:nth-child(6) { animation-delay: 0.35s; }
        #usa-app .categoria-card:nth-child(7) { animation-delay: 0.4s; }
        #usa-app .categoria-card:nth-child(8) { animation-delay: 0.45s; }
        #usa-app .categoria-card:nth-child(9) { animation-delay: 0.5s; }

        /* Efecto HOVER - cuando el usuario pasa el dedo/mouse */
        #usa-app .categoria-card:hover {
            /* Escala ligera */
            transform: scale(1.05) translateY(-5px);
            /* Sombra dorada brillante */
            box-shadow: 
                0 10px var(--cat-sombra) rgba(0, 0, 0, 0.5),
                0 0 25px var(--cat-brillo),
                inset 0 0 20px rgba(255, 215, 0, 0.1);
            /* Borde dorado */
            border-color: var(--oro);
        }

        /* Efecto al presionar (active) */
        #usa-app .categoria-card:active {
            transform: scale(0.98);
            transition: transform 0.1s ease;
        }

        /* Imagen de fondo de la categoria */
        #usa-app .categoria-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            /* Transicion suave para el zoom */
            transition: transform var(--cat-velocidad) ease;
        }

        /* Zoom de la imagen al hacer hover */
        #usa-app .categoria-card:hover img {
            transform: scale(1.15);
        }

        /* ====================================================================== 
           [ ✨ CAPA OSCURA CON DEGRADADO Y TEXTO ]
           ====================================================================== */
        #usa-app .categoria-overlay {
            position: absolute;
            inset: 0;
            /* Degradado de oscuro a transparente desde abajo */
            background: linear-gradient(
                to top,
                rgba(0, 0, 0, 0.95) 0%,
                rgba(0, 0, 0, 0.7) 30%,
                rgba(0, 0, 0, 0.3) 60%,
                transparent 100%
            );
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            align-items: center;
            padding: 15px;
            /* Transicion suave */
            transition: all var(--cat-velocidad) ease;
        }

        /* Cambio del degradado al hacer hover */
        #usa-app .categoria-card:hover .categoria-overlay {
            background: linear-gradient(
                to top,
                rgba(0, 0, 0, 0.98) 0%,
                rgba(0, 0, 0, 0.8) 40%,
                rgba(255, 215, 0, 0.1) 100%
            );
        }

        /* ====================================================================== 
           [ 📝 TEXTO DEL NOMBRE DE CATEGORIA ]
           ==================================================================
           Ajusta el tamaño del texto segun el tamaño de tus tarjetas.
           Para tarjetas grandes (250px+), usa 18px-22px
           Para tarjetas medianas (180px-250px), usa 14px-16px
           Para tarjetas pequeñas (menos de 180px), usa 12px-14px
           ================================================================== */
        #usa-app .categoria-nombre {
            /* TAMAÑO DEL TEXTO DEL NOMBRE DE CATEGORIA */
            font-size: 20px;
            /* GROSOR DE LA LETRA (400 = normal, 700 = negrita) */
            font-weight: 700;
            color: var(--texto);
            text-align: center;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.9);
            /* Efecto de brillo en el texto */
            transition: all var(--cat-velocidad) ease;
            z-index: 2;
            /* ESPACIO ENTRE LETRAS */
            letter-spacing: 0.5px;
        }

        /* Cambio del texto al hacer hover */
        #usa-app .categoria-card:hover .categoria-nombre {
            color: var(--oro);
            text-shadow: 
                0 0 10px rgba(255, 215, 0, 0.6),
                0 2px 8px rgba(0, 0, 0, 0.9);
            transform: translateY(-3px);
        }

        /* ====================================================================== 
           [ 🌟 EFECTO DE BRILLO DORADO EN ESQUINAS ]
           ====================================================================== */
        #usa-app .categoria-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(
                45deg,
                transparent 40%,
                rgba(255, 215, 0, 0.1) 50%,
                transparent 60%
            );
            transform: rotate(45deg) translateY(-100%);
            transition: transform 0.6s ease;
            pointer-events: none;
            z-index: 1;
        }

        /* Movimiento del brillo al hacer hover */
        #usa-app .categoria-card:hover::before {
            transform: rotate(45deg) translateY(100%);
        }

        /* ====================================================================== 
           [ 📱 ANIMACIONES ADICIONALES ]
           ====================================================================== */

        /* Animacion de entrada desde arriba para el titulo */
        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ====================================================================== 
           [ 🏪 PACKS MAYORISTAS - TARJETAS GRANDES ]
           ==================================================================
           ESTILOS ESPECIALES PARA LOS PRODUCTOS MAYORISTAS
           Estas tarjetas son mas grandes y llamativas que las normales
           ------------------------------------------------------------------
           PARA MODIFICAR:
           - --pack-tamano: Ancho maximo de la tarjeta
           - --pack-img-altura: Altura de la imagen
           - --pack-banner-tamano: Tamaño del texto del banner
           ================================================================== */
        
        /* Variables especificas para packs mayoristas */
        #usa-app {
            /* ANCHO MAXIMO DE LA TARJETA (una sola columna) */
            --pack-ancho: 100%;
            /* ALTURA DE LA IMAGEN DEL PACK */
            --pack-img-altura: 220px;
            /* TAMAÑO DEL TEXTO DEL BANNER */
            --pack-banner-tamano: 16px;
            /* TAMAÑO DEL PRECIO */
            --pack-precio-tamano: 22px;
            /* RADIO DE ESQUINAS */
            --pack-radio: 16px;
        }
        
        /* Contenedor de packs mayoristas */
        #usa-app #contenedor-mayoristas {
            display: flex;
            flex-direction: column;
            gap: 20px;
            padding: 10px 0;
        }
        
        /* Tarjeta individual de pack mayorista */
        #usa-app .tarjeta-mayorista {
            /* Ancho completo */
            width: var(--pack-ancho);
            /* Fondo oscuro */
            background: var(--card);
            /* Esquinas redondeadas */
            border-radius: var(--pack-radio);
            /* Borde dorado sutil */
            border: 2px solid var(--oro);
            /* Oculta contenido que se sale */
            overflow: hidden;
            /* Cursor de mano */
            cursor: pointer;
            /* Posicion relativa para elementos absolutos */
            position: relative;
            /* Sombra inicial */
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
            /* Transicion suave */
            transition: all 0.3s ease;
        }
        
        /* Efecto hover en la tarjeta de pack */
        #usa-app .tarjeta-mayorista:hover {
            /* Escala ligera */
            transform: scale(1.02);
            /* Sombra dorada */
            box-shadow: 
                0 8px 25px rgba(0, 0, 0, 0.5),
                0 0 30px rgba(255, 215, 0, 0.2);
            /* Borde mas brillante */
            border-color: #FFA500;
        }
        
        /* Efecto al presionar */
        #usa-app .tarjeta-mayorista:active {
            transform: scale(0.98);
        }
        
        /* Banner dorado con nombre del pack */
        #usa-app .banner-pack {
            /* Degradado dorado */
            background: linear-gradient(135deg, var(--oro), #FFA500);
            /* Padding generoso */
            padding: 14px;
            /* Texto centrado */
            text-align: center;
            /* Color negro */
            color: #000;
            /* Negrita */
            font-weight: bold;
            /* Tamaño de letra */
            font-size: var(--pack-banner-tamano);
            /* Sombra de texto */
            text-shadow: 0 1px 2px rgba(255, 255, 255, 0.3);
        }
        
        /* Imagen del pack mayorista */
        #usa-app .img-pack-mayorista {
            /* Ancho completo */
            width: 100%;
            /* Altura grande */
            height: var(--pack-img-altura);
            /* Ajusta imagen sin cortar */
            object-fit: contain;
            /* Fondo oscuro */
            background: var(--fondo);
            /* Padding alrededor */
            padding: 15px;
            /* Transicion suave */
            transition: transform 0.3s ease;
        }
        
        /* Zoom de imagen al hacer hover */
        #usa-app .tarjeta-mayorista:hover .img-pack-mayorista {
            transform: scale(1.05);
        }
        
        /* Contenedor de informacion del pack */
        #usa-app .info-pack {
            /* Padding generoso */
            padding: 16px;
            /* Texto centrado */
            text-align: center;
            /* Fondo ligeramente mas claro */
            background: linear-gradient(180deg, var(--card) 0%, var(--fondo) 100%);
        }
        
        /* Descripcion del pack */
        #usa-app .desc-pack {
            /* Tamaño de letra */
            font-size: 14px;
            /* Color gris */
            color: var(--texto-secundario);
            /* Margen inferior */
            margin-bottom: 12px;
            /* Line height */
            line-height: 1.4;
        }
        
        /* Contenedor de precios */
        #usa-app .precios-pack {
            /* Flexbox centrado */
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-bottom: 10px;
        }
        
        /* Precio actual del pack */
        #usa-app .precio-pack-actual {
            /* Tamaño grande */
            font-size: var(--pack-precio-tamano);
            /* Color dorado */
            color: var(--oro);
            /* Negrita */
            font-weight: bold;
        }
        
        /* Precio anterior tachado */
        #usa-app .precio-pack-antiguo {
            /* Tamaño mediano */
            font-size: 14px;
            /* Color gris */
            color: var(--texto-secundario);
            /* Tachado */
            text-decoration: line-through;
        }
        
        /* Texto de ahorro */
        #usa-app .ahorro-pack {
            /* Color verde exito */
            color: var(--exito);
            /* Tamaño de letra */
            font-size: 14px;
            /* Negrita */
            font-weight: bold;
            /* Margen inferior */
            margin-bottom: 15px;
            /* Padding */
            padding: 6px 12px;
            /* Fondo verde transparente */
            background: rgba(0, 200, 81, 0.1);
            /* Radio de esquinas */
            border-radius: 20px;
            /* En linea */
            display: inline-block;
        }
        
        /* Boton de compra del pack */
        #usa-app .btn-pack {
            /* Ancho completo */
            width: 100%;
            /* Padding */
            padding: 14px;
            /* Fondo dorado */
            background: var(--oro);
            /* Color negro */
            color: #000;
            /* Sin borde */
            border: none;
            /* Esquinas redondeadas */
            border-radius: 25px;
            /* Tamaño de letra */
            font-size: 14px;
            /* Negrita */
            font-weight: 700;
            /* Cursor de mano */
            cursor: pointer;
            /* Transicion */
            transition: all 0.2s ease;
            /* Sombra */
            box-shadow: 0 4px 10px rgba(255, 215, 0, 0.3);
        }
        
        /* Hover del boton */
        #usa-app .btn-pack:hover {
            /* Mas brillante */
            filter: brightness(1.1);
            /* Escala */
            transform: scale(1.02);
        }
        
        /* Boton favorito en packs (mas grande) */
        #usa-app .tarjeta-mayorista .btn-favorito {
            width: 38px;
            height: 38px;
            top: 50px;
            right: 10px;
            background: rgba(0, 0, 0, 0.7);
            border: 1px solid var(--oro);
        }

</style>
</head>
<body>
    <div id="usa-app">

        <header class="barra-superior">
            <button class="btn-menu" onclick="window.alternarMenuLateral()">
                <span></span><span></span><span></span>
            </button>

            <div class="contenedor-logo" onclick="window.mostrarPagina('inicio')">
                <img decoding="async" src="http://usafitness.cl/wp-content/uploads/2023/04/usafitness-logo-16028631821-Editado.png " alt="USA Fitness" class="logo-img" style="height: 32px; width: auto;">
            </div>

            <div class="iconos-derecha">
                <button class="btn-icono" onclick="window.gestionarClicCuenta()">
                    <img decoding="async" src="https://api.iconify.design/bx/user.svg?color=white " style="width: 24px; height: 24px;">
                </button>
                <button class="btn-icono" onclick="window.alternarPanelFavoritos()">
                    <img decoding="async" src="https://api.iconify.design/bx/heart.svg?color=white " style="width: 24px; height: 24px;">
                    <span class="globo-contador" id="contador-favoritos" style="display:none">0</span>
                </button>
                <button class="btn-icono" onclick="window.mostrarPagina('carrito')">
                    <img decoding="async" src="https://api.iconify.design/bx/cart.svg?color=white " style="width: 24px; height: 24px;">
                    <span class="globo-contador" id="contador-carrito" style="display:none">0</span>
                </button>
            </div>
        </header>

        <!-- ==================================================================
             [ 🔍 BUSCADOR EN HEADER (CABECERA) ]
             ================================================================== -->
        <div class="header-buscador-contenedor">
            <div class="header-buscador-caja">
                <input type="text" 
                       class="header-buscador-input" 
                       id="header-input-busqueda"
                       placeholder="Buscar productos..." 
                       oninput="window.autocompletarHeader(this.value)"
                       autocomplete="off">
                <button class="header-buscador-boton" onclick="window.ejecutarBusquedaHeader()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <circle cx="11" cy="11" r="8"></circle>
                        <path d="m21 21-4.35-4.35"></path>
                    </svg>
                </button>
            </div>
            <!-- Resultados de autocompletar -->
            <div class="header-buscador-resultados" id="header-resultados-busqueda"></div>
        </div>

        <div class="contenedor-principal">

            <div id="pagina-inicio" class="pagina">

                <div class="carrusel-hero" id="hero-inicio">
                    <div class="slide-hero activo" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.8)), url('https://images.unsplash.com/photo-1593095948071-474c5cc2989d?w=800&fit=crop ');">
                        <div class="contenido-hero">
                            <span class="etiqueta-hero">SOMOS MAYORISTAS</span>
                            <h2>AUMENTA TUS GANANCIAS</h2>
                            <p>Los mejores precios por mayor en suplementos. Combina sabores a tu gusto.</p>
                        </div>
                    </div>

                    <div class="slide-hero" style="background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.8)), url('https://images.unsplash.com/photo-1517836357463-d25dfeac3438?w=800&fit=crop ');">
                        <div class="contenido-hero">
                            <span class="etiqueta-hero" style="background:var(--exito);">ENVÍOS A TODO CHILE</span>
                            <h2>STARKEN EN 24 HRS</h2>
                            <p>Despacho GRATIS en todas tus compras sobre $49.990.</p>
                        </div>
                    </div>
                    <div class="puntos-hero">
                        <button class="punto activo" onclick="window.irASlide(0)"></button>
                        <button class="punto" onclick="window.irASlide(1)"></button>
                    </div>
                </div>

                <!-- ====================================================================== 
     [ 📦 SECCION CATEGORIAS - DISEÑO VERTICAL CUADRADO ]
     ====================================================================== 

     INSTRUCCIONES DE MODIFICACION:
     -------------------------------
     - Para cambiar la imagen: Modifica el atributo "src" de la etiqueta <img>
     - Para cambiar el nombre: Modifica el texto dentro de <span class="categoria-nombre">
     - Para cambiar la categoria: Modifica el valor en onclick="window.filtrarCategoria('nombre')"
     - Para agregar una nueva categoria: Copia y pega un bloque <div class="categoria-card">...</div>

-->
<div id="ancla-categorias" class="seccion-categorias">

    <!-- Titulo de la seccion con barra decorativa dorada -->
    <h2 class="titulo-categorias">Categorias</h2>

    <!-- Contenedor vertical de categorias - UNA EN UNA -->
    <div class="lista-categorias-vertical">

        <!-- ============================================
             CATEGORIA 1: PROTEINAS
             ============================================ -->
        <div class="categoria-card" onclick="window.filtrarCategoria('proteinas')">
            <!-- Imagen de fondo de la categoria -->
            <img decoding="async" src="http://usafitness.cl/wp-content/uploads/2026/04/Gemini_Generated_Image_ghckhcghckhcghck.png" alt="Proteinas">
            <!-- Capa oscura con el nombre -->
            <div class="categoria-overlay">
                <span class="categoria-nombre">Proteinas</span>
            </div>
        </div>

        <!-- ============================================
             CATEGORIA 2: CREATINAS
             ============================================ -->
        <div class="categoria-card" onclick="window.filtrarCategoria('creatinas')">
            <img decoding="async" src="http://usafitness.cl/wp-content/uploads/2026/04/Gemini_Generated_Image_gkwiregkwiregkwi.png" alt="Creatinas">
            <div class="categoria-overlay">
                <span class="categoria-nombre">Creatinas</span>
            </div>
        </div>

        <!-- ============================================
             CATEGORIA 3: GANADORES
             ============================================ -->
        <div class="categoria-card" onclick="window.filtrarCategoria('ganadores')">
            <img decoding="async" src="http://usafitness.cl/wp-content/uploads/2026/04/Gemini_Generated_Image_qhhfwbqhhfwbqhhf.png" alt="Ganadores">
            <div class="categoria-overlay">
                <span class="categoria-nombre">Ganadores</span>
            </div>
        </div>

        <!-- ============================================
             CATEGORIA 4: QUEMADORES
             ============================================ -->
        <div class="categoria-card" onclick="window.filtrarCategoria('quemadores')">
            <img decoding="async" src="http://usafitness.cl/wp-content/uploads/2026/04/Gemini_Generated_Image_4uxxr74uxxr74uxx.png" alt="Quemadores">
            <div class="categoria-overlay">
                <span class="categoria-nombre">Quemadores</span>
            </div>
        </div>

        <!-- ============================================
             CATEGORIA 5: MAYORISTAS (Proteinas)
             ============================================ -->
        <div class="categoria-card" onclick="window.mostrarPagina('mayoristas')">
            <img decoding="async" src="http://usafitness.cl/wp-content/uploads/2026/04/Gemini_Generated_Image_mr6ea0mr6ea0mr6e.png" alt="Mayoristas">
            <div class="categoria-overlay">
                <span class="categoria-nombre">Mayoristas (Packs)</span>
            </div>
        </div>

        <!-- ============================================
             CATEGORIA 6: BCAA
             ============================================ -->
        <div class="categoria-card" onclick="window.filtrarCategoria('bcaa')">
            <img decoding="async" src="http://usafitness.cl/wp-content/uploads/2026/04/Gemini_Generated_Image_w28f5lw28f5lw28f.png" alt="BCAA">
            <div class="categoria-overlay">
                <span class="categoria-nombre">BCAA</span>
            </div>
        </div>

        <!-- ============================================
             CATEGORIA 7: AMINOACIDOS
             ============================================ -->
        <div class="categoria-card" onclick="window.filtrarCategoria('aminoacidos')">
            <img decoding="async" src="http://usafitness.cl/wp-content/uploads/2026/04/Gemini_Generated_Image_fub9ovfub9ovfub9.png" alt="Aminoacidos">
            <div class="categoria-overlay">
                <span class="categoria-nombre">Aminoacidos</span>
            </div>
        </div>

        <!-- ============================================
             CATEGORIA 8: VITAMINAS
             ============================================ -->
        <div class="categoria-card" onclick="window.filtrarCategoria('vitaminas')">
            <img decoding="async" src="http://usafitness.cl/wp-content/uploads/2026/04/Gemini_Generated_Image_xaxczmxaxczmxaxc.png" alt="Vitaminas">
            <div class="categoria-overlay">
                <span class="categoria-nombre">Vitaminas</span>
            </div>
        </div>

        <!-- ============================================
             CATEGORIA 9: ACCESORIOS
             ============================================ -->
        <div class="categoria-card" onclick="window.filtrarCategoria('accesorios')">
            <img decoding="async" src="http://usafitness.cl/wp-content/uploads/2026/04/Gemini_Generated_Image_8z14ku8z14ku8z14.png" alt="Accesorios">
            <div class="categoria-overlay">
                <span class="categoria-nombre">Accesorios</span>
            </div>
        </div>

    </div><!-- Fin lista-categorias-vertical -->

</div><!-- Fin seccion-categorias -->

<!-- INICIO SECCION DESTACADOS -->
            <div id="ancla-destacados">
                    <h2 class="titulo-seccion">Destacados</h2>
                    <div class="scroll-horizontal" id="contenedor-destacados"></div>
                </div>

                <div>
                    <h2 class="titulo-seccion">Más de 5,000 Clientes Felices</h2>
                    <div class="scroll-horizontal" id="contenedor-resenas-inicio"></div>
                </div>

                <!-- ==================================================================
                     [ 🏋️ CARRUSEL DE CREATINAS - AUTO-REPRODUCCION ]
                     ================================================================== -->
                <div id="ancla-creatinas-carrusel">
                    <h2 class="titulo-seccion">Creatinas</h2>
                    <div class="carrusel-creatinas-contenedor">
                        <div class="carrusel-creatinas" id="contenedor-creatinas-carrusel"></div>
                    </div>
                </div>
            </div>

            <div id="pagina-catalogo" class="pagina oculto">
                <h2 class="titulo-seccion" id="titulo-catalogo">Catálogo</h2>
                
                <!-- Botones de Filtrar y Ordenar -->
                <div class="catalogo-filtros">
                    <button class="btn-filtro" onclick="window.mostrarFiltrosCatalogo()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
                        </svg>
                        Filtrar
                    </button>
                    <button class="btn-ordenar" onclick="window.mostrarOrdenarCatalogo()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 5h10"></path>
                            <path d="M11 9h7"></path>
                            <path d="M11 13h4"></path>
                            <path d="M3 17l3 3 3-3"></path>
                            <path d="M6 18V4"></path>
                        </svg>
                        Ordenar
                    </button>
                </div>
                
                <div class="lista-productos" id="contenedor-productos"></div>
            </div>

            <div id="pagina-mayoristas" class="pagina oculto">
                <h2 class="titulo-seccion">Packs Mayoristas</h2>

                <div style="background:rgba(255,215,0,0.1); border:1px solid rgba(255,215,0,0.3); border-radius:10px; padding:12px; margin-bottom:16px;">
                    <div style="color:var(--oro); font-weight:bold; margin-bottom:5px;">Compra al por Mayor</div>
                    <div style="font-size:12px; color:var(--texto-secundario);">Elige los sabores que quieras. Si llevas 2 promos, podrás elegir el doble de sabores.</div>
                </div>
                <div id="contenedor-mayoristas"></div>
            </div>

            <div id="pagina-contacto" class="pagina oculto">
                <h2 class="titulo-seccion">Contacto y Ubicación</h2>
                <div class="tarjeta-contacto">
                    <div class="item-contacto"><img decoding="async" src="https://api.iconify.design/bx/map.svg?color=white " style="width:24px; height:24px;"><div class="texto-contacto"><strong>Nuestras Tiendas :</strong> <br> • Sucursal Norte
                "Av. Heroes de la concepcion 2555, local 75 (Iquique)
                    <br> • Horario: "Lunes a Sábado: 09:00 - 18:00" <br>• Sucursal zona central (En construccion) "San Pablo 1055, Region Metropolitana"<br>• Horario: Fecha De Inaguracion (24/07/2026)<br> • Bodega de Distribucion zona central<br> "Pdte Jorge Alessandri Rodríguez 11500, San Bernardo, Región Metropolitana local N5"<br> • Horario: Luness a Jueves: 10:00 - 17:00   </div></div>
                    <div class="item-contacto"><img decoding="async" src="https://api.iconify.design/bx/phone.svg?color=white " style="width:24px; height:24px;"><div class="texto-contacto"><strong>Llámanos o WhatsApp</strong>+56 9 3621 1293</div></div>
                    <div class="item-contacto"><img decoding="async" src="https://api.iconify.design/bx/envelope.svg?color=white " style="width:24px; height:24px;"><div class="texto-contacto"><strong>Correo Electrónico</strong> contacto@usafitness.cl</div></div>
                </div>

                <div style="border-radius: 12px; overflow: hidden; border: 1px solid var(--borde);">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3743.6168966472537!2d-70.14764671734316!3d-20.233234732812946!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9152140a35f1fd57%3A0x8b12aa085f683e93!2sAv.%20H%C3%A9roes%20de%20la%20Concepci%C3%B3n%202555%2C%20Iquique%2C%20Tarapac%C3%A1!5e0!3m2!1ses-419!2scl!4v1775336544135!5m2!1ses-419!2scl" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy=" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" width="100%" height="250" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
                </div>
            </div>

            <!-- ==================================================================
                 [ 🛡️ PAGINA DE AUTENTICIDAD ]
                 ================================================================== -->
            <div id="pagina-autenticidad" class="pagina oculto">
                <h2 class="titulo-seccion">Autenticidad Garantizada</h2>
                
                <!-- Seccion 1: Que es la autenticidad -->
                <div class="autenticidad-seccion">
                    <h3 class="autenticidad-titulo-principal">¿Qué la autenticidad garantizada?</h3>
                    <p class="autenticidad-texto">
                        Cuando compras en USA Fitness tienes tranquilidad y seguridad, implementamos medidas y procesos para asegurar que nuestros productos son genuinos, seguros y de alta calidad.
                    </p>
                </div>

                <!-- Seccion 2: Como la garantizamos -->
                <div class="autenticidad-seccion">
                    <h3 class="autenticidad-titulo-principal">¿Cómo la garantizamos?</h3>
                    <p class="autenticidad-texto">
                        La garantizamos mediante cartas de marcas que acreditan nuestra representación como distribuidor oficial en Chile, también contamos con la autorización del ministerio de salud y además con análisis en laboratorio de productos.
                    </p>
                </div>

                <!-- Tarjetas de garantias -->
                <div class="autenticidad-tarjetas">
                    <!-- Tarjeta 1: Cartas de Representacion -->
                    <div class="autenticidad-card">
                        <div class="autenticidad-icono">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                                <line x1="16" y1="13" x2="8" y2="13"/>
                                <line x1="16" y1="17" x2="8" y2="17"/>
                                <polyline points="10 9 9 9 8 9"/>
                            </svg>
                        </div>
                        <h4 class="autenticidad-card-titulo">Cartas de Representación</h4>
                        <p class="autenticidad-card-texto">
                            Son documentos formales que acredita a una empresa como representante autorizado de una marca o producto para un mercado en específico, baja la condición de exhibir sin adulterar la marca y nombre original del producto.
                        </p>
                    </div>

                    <!-- Tarjeta 2: Analisis de Productos -->
                    <div class="autenticidad-card">
                        <div class="autenticidad-icono">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M10 2h4"/>
                                <path d="M12 14v7"/>
                                <path d="M12 2v4"/>
                                <path d="M19.5 9l-7.5 5-7.5-5"/>
                                <path d="M19.5 5l-7.5 5-7.5-5"/>
                                <path d="M12 9v5"/>
                                <path d="M8 14l4 3 4-3"/>
                            </svg>
                        </div>
                        <h4 class="autenticidad-card-titulo">Análisis de Productos</h4>
                        <p class="autenticidad-card-texto">
                            Son dedicados a aquellos productos que requieren identificar la pureza de sus compuestos para así ser consumidos con total seguridad.
                        </p>
                    </div>

                    <!-- Tarjeta 3: Resolucion SEREMI -->
                    <div class="autenticidad-card">
                        <div class="autenticidad-icono">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                                <path d="M9 15l2 2 4-4"/>
                            </svg>
                        </div>
                        <h4 class="autenticidad-card-titulo">Resolución SEREMI de Salud</h4>
                        <p class="autenticidad-card-texto">
                            La seremi de salud evalúa el establecimiento, procesos, y calidad del producto final acorde al código sanitario y sus requerimientos.
                        </p>
                    </div>

                    <!-- Tarjeta 4: Sellos de Validez -->
                    <div class="autenticidad-card">
                        <div class="autenticidad-icono">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <circle cx="12" cy="12" r="10"/>
                                <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
                                <line x1="9" y1="9" x2="9.01" y2="9"/>
                                <line x1="15" y1="9" x2="15.01" y2="9"/>
                            </svg>
                        </div>
                        <h4 class="autenticidad-card-titulo">Sellos de Validez</h4>
                        <p class="autenticidad-card-texto">
                            Los sellos de validez en suplementos deportivos son etiquetas de seguridad que garantizan la autenticidad y calidad del producto.
                        </p>
                    </div>
                </div>

                <!-- Seccion Cartas de Representacion -->
                <div class="autenticidad-seccion-final">
                    <h3 class="autenticidad-titulo-final">Cartas de representación</h3>
                    <p class="autenticidad-texto-final">
                        Somos orgullosos distribuidores oficiales de Universal Nutrition y sus marcas Animal, Universal y Universal U. Como también de Ghost y Redcon 1.
                    </p>
                </div>
            </div>

            <div id="pagina-registro" class="pagina oculto">
                <h2 class="titulo-seccion">Crear Cuenta</h2>
                <div class="tarjeta-auth">
                    <p style="font-size:12px; color:var(--texto-secundario); margin-bottom:20px;">Regístrate para ver tu historial de compras y guardar favoritos.</p>
                    <form onsubmit="return false;">
                        <div class="grupo-form"><div class="envoltura-input"><input type="text" class="input-form" id="reg-nombre" placeholder="Tu Nombre" required oninput="window.validarCampoEnVivo(this, 'texto')"><span class="icono-estado"></span></div><span class="msj-error">Ingresa un nombre válido</span></div>
                        <div class="grupo-form"><div class="envoltura-input"><input type="email" class="input-form" id="reg-correo" placeholder="Correo Electrónico" required oninput="window.validarCampoEnVivo(this, 'correo')"><span class="icono-estado"></span></div><span class="msj-error">Ingresa un correo válido (ej: nombre@mail.com)</span></div>
                        <div class="grupo-form"><div class="envoltura-input"><input type="password" class="input-form" id="reg-clave" placeholder="Contraseña (Mín. 6 letras)" required oninput="window.validarCampoEnVivo(this, 'clave')"><span class="icono-estado"></span></div><span class="msj-error">La contraseña es muy corta</span></div>
                        <button class="btn-principal" onclick="window.registrarUsuario()">Registrarme</button>
                    </form>
                    <span class="auth-link" style="color:var(--oro); font-size:12px; cursor:pointer; margin-top:15px; display:inline-block;" onclick="window.mostrarPagina('login')">¿Ya tienes cuenta? Inicia sesión aquí</span>
                </div>
            </div>

