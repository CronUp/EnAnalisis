                                <input type="radio" name="tipo-documento" value="boleta" checked style="accent-color:var(--oro); width:18px; height:18px;">
                                <span style="font-size:14px;">Boleta</span>
                            </label>
                            <label style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:12px 20px; background:var(--fondo); border:1px solid var(--borde); border-radius:10px; flex:1; transition:all 0.2s;">
                                <input type="radio" name="tipo-documento" value="factura" style="accent-color:var(--oro); width:18px; height:18px;">
